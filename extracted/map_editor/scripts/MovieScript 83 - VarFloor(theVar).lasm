on VarFloor theVar
  [  0] getparam 0 .............................. <theVar>
  [  2] pushint16 1000 .......................... <1000>
  [  5] mul ..................................... <theVar * 1000>
  [  6] pusharglist 1 ........................... <theVar * 1000>
  [  8] extcall 90 .............................. <integer(theVar * 1000)>
  [ 10] setlocal 0 .............................. theInt = integer(theVar * 1000)
  [ 12] getlocal 0 .............................. <theInt>
  [ 14] pushint16 1000 .......................... <1000>
  [ 17] mod ..................................... <theInt mod 1000>
  [ 18] setlocal 1 .............................. theRemainder = theInt mod 1000
  [ 20] getlocal 0 .............................. <theInt>
  [ 22] getlocal 1 .............................. <theRemainder>
  [ 24] sub ..................................... <theInt - theRemainder>
  [ 25] setlocal 0 .............................. theInt = theInt - theRemainder
  [ 27] getlocal 0 .............................. <theInt>
  [ 29] pushint16 1000 .......................... <1000>
  [ 32] div ..................................... <theInt / 1000>
  [ 33] setlocal 0 .............................. theInt = theInt / 1000
  [ 35] getlocal 0 .............................. <theInt>
  [ 37] pusharglistnoret 1 ...................... <theInt>
  [ 39] extcall 24 .............................. return theInt
  [ 41] ret
end
