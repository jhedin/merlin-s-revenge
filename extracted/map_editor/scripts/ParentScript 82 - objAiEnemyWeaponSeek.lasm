  [ 41] objcall 699 ............................. <g.weaponMaster.getWeapon(me, [#pan, #pad, #pug, #sci, #spd, #swd])>
  [ 44] setprop 686 ............................. pMyWeapon = g.weaponMaster.getWeapon(me, [#pan, #pad, #pug, #sci, #spd, #swd])
  [ 47] jmp [ 64]
  [ 50] peek 0
  [ 52] pushsymb 689 ............................ <#collectWeapon>
  [ 55] eq
  [ 56] jmpifz [ 64] ............................ (case) #collectWeapon:
  [ 59] pusharglistnoret 0 ...................... <>
  [ 61] extcall 404 ............................. nothing()
