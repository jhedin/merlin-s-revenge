  [ 75] getparam 0 .............................. <me>
  [ 77] pushsymb 688 ............................ <#seekWeapon>
  [ 80] pusharglistnoret 2 ...................... <me, #seekWeapon>
  [ 82] objcall 76 .............................. me.goMode(#seekWeapon)
  [ 84] getparam 0 .............................. <me>
  [ 86] pushsymb 689 ............................ <#collectWeapon>
  [ 89] pusharglistnoret 2 ...................... <me, #collectWeapon>
  [ 91] objcall 76 .............................. me.goMode(#collectWeapon)
  [ 93] jmp [104] ............................... (case) otherwise:
