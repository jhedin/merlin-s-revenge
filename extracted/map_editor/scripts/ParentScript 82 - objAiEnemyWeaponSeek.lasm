  [  3] pushsymb 22 ............................. <#none>
  [  5] nteq .................................... <pMyWeapon <> #none>
  [  6] jmpifz [ 35] ............................ if pMyWeapon <> #none then
  [  9] getprop 686 ............................. <pMyWeapon>
  [ 12] pusharglist 1 ........................... <pMyWeapon>
  [ 14] objcall 690 ............................. <pMyWeapon.isCarried()>
  [ 17] jmpifz [ 35] ............................ if pMyWeapon.isCarried() then
  [ 20] getprop 686 ............................. <pMyWeapon>
