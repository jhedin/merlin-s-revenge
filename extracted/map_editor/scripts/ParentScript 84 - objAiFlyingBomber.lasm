  [ 75] setlocal 3 .............................. attackRect = me.pPlayer.getRect().inflate(reach[1], reach[2])
  [ 77] getparam 0 .............................. <me>
  [ 79] getlocal 2 .............................. <idealRect>
  [ 81] pusharglistnoret 2 ...................... <me, idealRect>
  [ 83] objcall 352 ............................. me.updateMoveToRect(idealRect)
  [ 86] getparam 0 .............................. <me>
  [ 88] getlocal 3 .............................. <attackRect>
