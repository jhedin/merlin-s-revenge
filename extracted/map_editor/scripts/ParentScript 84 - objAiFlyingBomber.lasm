  [ 92] objcall 344 ............................. <me.checkInRect(attackRect)>
  [ 95] setlocal 4 .............................. inRect = me.checkInRect(attackRect)
  [ 97] getlocal 4 .............................. <inRect>
  [ 99] pushint8 1 .............................. <1>
  [101] eq ...................................... <inRect = 1>
  [102] jmpifz [112] ............................ if inRect = 1 then / else
  [105] pushint8 1 .............................. <1>
  [107] setlocal 5 .............................. fin = 1
  [109] jmp [115]
  [112] pushzero ................................ <0>
