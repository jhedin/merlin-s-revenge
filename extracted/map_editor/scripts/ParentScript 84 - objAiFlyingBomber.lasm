  [ 42] add ..................................... <me.pPlayer.getRect() + rect(attackLoc, attackLoc)>
  [ 43] setlocal 2 .............................. idealRect = me.pPlayer.getRect() + rect(attackLoc, attackLoc)
  [ 45] getparam 0 .............................. <me>
  [ 47] getchainedprop 354 ...................... <me.pPlayer>
  [ 50] pusharglist 1 ........................... <me.pPlayer>
  [ 52] objcall 383 ............................. <me.pPlayer.getRect()>
  [ 55] getlocal 1 .............................. <reach>
  [ 57] pushint8 1 .............................. <1>
  [ 59] pusharglist 2 ........................... <reach, 1>
  [ 61] objcall 38 .............................. <reach[1]>
  [ 63] getlocal 1 .............................. <reach>
  [ 65] pushint8 2 .............................. <2>
  [ 67] pusharglist 2 ........................... <reach, 2>
  [ 69] objcall 38 .............................. <reach[2]>
  [ 71] pusharglist 3 ........................... <me.pPlayer.getRect(), reach[1], reach[2]>
