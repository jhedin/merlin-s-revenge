property ancestor
global g

on new me
  [  0] pushcons 0 .............................. <"objAiEnemy">
  [  2] pusharglist 1 ........................... <"objAiEnemy">
  [  4] extcall 27 .............................. <script("objAiEnemy")>
  [  6] pusharglist 1 ........................... <script("objAiEnemy")>
  [  8] extcall 0 ............................... <new(script("objAiEnemy"))>
  [ 10] setprop 77 .............................. ancestor = new(script("objAiEnemy"))
  [ 12] getparam 0 .............................. <me>
  [ 14] pusharglistnoret 1 ...................... <me>
  [ 16] extcall 17 .............................. return me
  [ 18] ret
end

on init me, player
  [  0] getprop 77 .............................. <ancestor>
  [  2] getparam 1 .............................. <player>
  [  4] pusharglistnoret 2 ...................... <ancestor, player>
  [  6] objcall 1 ............................... ancestor.init(player)
  [  8] ret
end

on updateMoveToAttack me
