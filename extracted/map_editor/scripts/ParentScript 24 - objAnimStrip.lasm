end

on setDelay me, newDelay
  [  0] getprop 119 ............................. <pDelay>
  [  2] pushsymb 123 ............................ <#tim>
  [  4] pushint8 2 .............................. <2>
  [  6] getparam 1 .............................. <newDelay>
  [  8] pusharglistnoret 4 ...................... <pDelay, #tim, 2, newDelay>
  [ 10] objcall 124 ............................. pDelay.tim[2] = newDelay
  [ 12] ret
end
