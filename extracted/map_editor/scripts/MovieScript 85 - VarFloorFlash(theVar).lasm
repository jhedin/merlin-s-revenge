global gMath

on VarFloorFlash theVar
  [  0] getglobal 154 ........................... <gMath>
  [  2] getparam 0 .............................. <theVar>
  [  4] pusharglist 2 ........................... <gMath, theVar>
  [  6] objcall 155 ............................. <gMath.floor(theVar)>
  [  8] pusharglistnoret 1 ...................... <gMath.floor(theVar)>
  [ 10] extcall 24 .............................. return gMath.floor(theVar)
  [ 12] ret
end
