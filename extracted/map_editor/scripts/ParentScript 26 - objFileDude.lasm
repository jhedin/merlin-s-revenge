  [ 32] pushcons 6 .............................. <".txt">
  [ 34] setprop 186 ............................. pSaveType = ".txt"
  [ 36] ret
end

on finish me
  [  0] pushzero ................................ <0>
  [  1] setlocal 0 .............................. pFObj = 0
  [  3] getparam 0 .............................. <me>
  [  5] getchainedprop 77 ....................... <me.ancestor>
  [  7] pusharglistnoret 1 ...................... <me.ancestor>
  [  9] objcall 39 .............................. me.ancestor.finish()
  [ 11] ret
end

on folderConfirm me, thepath
