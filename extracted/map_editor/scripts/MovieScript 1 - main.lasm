  [ 99] pusharglistnoret 1 ...................... <g.movieMaster>
  [101] objcall 27 .............................. g.movieMaster.start()
  [103] ret
end

on nextframe
  [  0] getglobal 12 ............................ <gFrameNum>
  [  2] pushint8 1 .............................. <1>
  [  4] add ..................................... <gFrameNum + 1>
  [  5] setglobal 12 ............................ gFrameNum = gFrameNum + 1
  [  7] getglobal 7 ............................. <g>
  [  9] getchainedprop 28 ....................... <g.updater>
  [ 11] pusharglistnoret 1 ...................... <g.updater>
  [ 13] objcall 29 .............................. g.updater.updatePrgs()
  [ 15] pusharglistnoret 0 ...................... <>
  [ 17] extcall 30 .............................. updateStage()
  [ 19] ret
end

on stopMovie
  [  0] pusharglistnoret 0 ...................... <>
  [  2] localcall 6 ............................. stopMainObjects()
  [  4] getglobal 9 ............................. <r>
  [  6] pushcons 3 .............................. <"-- < end of movie > ">
