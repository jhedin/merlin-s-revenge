  [ 55] setparam 1 .............................. sym = #fly
  [ 57] jmp [ 74]
  [ 60] peek 0
  [ 62] pushsymb 1316 ........................... <#fall>
  [ 65] eq
  [ 66] jmpifz [ 74] ............................ (case) #fall:
