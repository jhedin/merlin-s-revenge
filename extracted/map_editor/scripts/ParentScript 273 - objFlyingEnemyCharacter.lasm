  [ 17] peek 0 .................................. case animSym of
  [ 19] pushsymb 263 ............................ <#fly>
  [ 22] eq
  [ 23] jmpifz [ 56] ............................ (case) #fly:
  [ 26] getparam 0 .............................. <me>
  [ 28] pusharglist 1 ........................... <me>
  [ 30] objcall 400 ............................. <me.getAnimFrame()>
  [ 33] getprop 1477 ............................ <pFlapFrame>
  [ 36] eq ...................................... <me.getAnimFrame() = pFlapFrame>
