  [ 40] getparam 0 .............................. <me>
  [ 42] getchainedprop 67 ....................... <me.id>
  [ 44] getchainedprop 66 ....................... <me.id.bigMe>
  [ 46] getprop 1478 ............................ <pJumpType>
  [ 49] pusharglistnoret 2 ...................... <me.id.bigMe, pJumpType>
  [ 51] objcall 76 .............................. me.id.bigMe.goMode(pJumpType)
  [ 53] jmp [ 78]
  [ 56] peek 0
  [ 58] pushsymb 1479 ........................... <#glide>
  [ 61] eq
  [ 62] jmpifz [ 78] ............................ (case) #glide:
  [ 65] getparam 0 .............................. <me>
  [ 67] getchainedprop 67 ....................... <me.id>
  [ 69] getchainedprop 66 ....................... <me.id.bigMe>
  [ 71] pushsymb 1381 ........................... <#jump>
  [ 74] pusharglistnoret 2 ...................... <me.id.bigMe, #jump>
  [ 76] objcall 76 .............................. me.id.bigMe.goMode(#jump)
  [ 78] pop 1 ................................... end case
  [ 80] ret
end

on getAnimSym me, sym
  [  0] getparam 1 .............................. <sym>
  [  2] pushsymb 22 ............................. <#none>
  [  4] eq ...................................... <sym = #none>
