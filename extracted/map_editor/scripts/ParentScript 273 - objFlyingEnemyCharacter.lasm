  [ 11] getparam 0 .............................. <me>
  [ 13] pusharglistnoret 1 ...................... <me>
  [ 15] objcall 756 ............................. me.frictionYOff()
  [ 18] jmp [ 64]
  [ 21] peek 0
  [ 23] pushsymb 365 ............................ <#reel_landed>
  [ 26] eq
