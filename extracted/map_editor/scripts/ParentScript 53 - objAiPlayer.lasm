  [ 15] pusharglistnoret 2 ...................... <me, #playerControl>
  [ 17] objcall 76 .............................. me.goMode(#playerControl)
  [ 19] ret
end

on characterModeChanged me, newCharMode
  [  0] getparam 1 .............................. <newCharMode>
  [  2] peek 0 .................................. case newCharMode of
  [  4] pushsymb 409 ............................ <#die>
  [  7] eq
  [  8] jmpifz [ 20] ............................ (case) #die:
  [ 11] getparam 0 .............................. <me>
  [ 13] pushsymb 367 ............................ <#dazed>
  [ 16] pusharglistnoret 2 ...................... <me, #dazed>
  [ 18] objcall 76 .............................. me.goMode(#dazed)
  [ 20] pop 1
  [ 22] ret
end

on finish me
  [  0] getprop 77 .............................. <ancestor>
  [  2] pusharglistnoret 1 ...................... <ancestor>
  [  4] objcall 39 .............................. ancestor.finish()
  [  6] ret
end

