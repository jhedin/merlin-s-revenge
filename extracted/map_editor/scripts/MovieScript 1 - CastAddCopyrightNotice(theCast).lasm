on CastAddCopyrightNotice theCast
  [  0] getparam 0 .............................. <theCast>
  [  2] pushint8 2 .............................. <2>
  [  4] get 8 ................................... <the number of castMembers of castLib theCast>
  [  6] setlocal 0 .............................. nummem = the number of castMembers of castLib theCast
  [  8] pushcons 0 .............................. <"Copyright Notice">
  [ 10] pusharglist 1 ........................... <"Copyright Notice">
  [ 12] extcall 1 ............................... <member("Copyright Notice")>
  [ 14] getobjprop 2 ............................ <member("Copyright Notice").text>
  [ 16] setlocal 1 .............................. copyrightNotice = member("Copyright Notice").text
  [ 18] pushint8 1 .............................. <1>
  [ 20] setlocal 2
  [ 22] getlocal 2
  [ 24] getlocal 0 .............................. <nummem>
  [ 26] lteq
  [ 27] jmpifz [114] ............................ repeat with i = 1 to nummem
  [ 30] getlocal 2 .............................. <i>
  [ 32] getparam 0 .............................. <theCast>
  [ 34] pusharglist 2 ........................... <i, theCast>
  [ 36] extcall 1 ............................... <member(i, theCast)>
  [ 38] setlocal 3 .............................. nMember = member(i, theCast)
  [ 40] getlocal 3 .............................. <nMember>
  [ 42] getobjprop 3 ............................ <nMember.fileName>
  [ 44] pushcons 1 .............................. <EMPTY>
  [ 46] eq ...................................... <nMember.fileName = EMPTY>
  [ 47] jmpifz [ 53] ............................ if nMember.fileName = EMPTY then
  [ 50] jmp [105] ............................... next repeat
  [ 53] getlocal 3 .............................. <nMember>
  [ 55] getobjprop 4 ............................ <nMember.scriptText>
  [ 57] setlocal 4 .............................. nScriptText = nMember.scriptText
  [ 59] getlocal 4 .............................. <nScriptText>
  [ 61] pushsymb 5 .............................. <#line>
  [ 63] pushint8 1 .............................. <1>
  [ 65] pusharglist 3 ........................... <nScriptText, #line, 1>
  [ 67] objcall 6 ............................... <nScriptText.line[1]>
  [ 69] getlocal 1 .............................. <copyrightNotice>
  [ 71] pushsymb 5 .............................. <#line>
  [ 73] pushint8 1 .............................. <1>
  [ 75] pusharglist 3 ........................... <copyrightNotice, #line, 1>
  [ 77] objcall 6 ............................... <copyrightNotice.line[1]>
  [ 79] eq ...................................... <nScriptText.line[1] = copyrightNotice.line[1]>
  [ 80] jmpifz [ 86] ............................ if nScriptText.line[1] = copyrightNotice.line[1] then
  [ 83] jmp [105] ............................... next repeat
  [ 86] getlocal 1 .............................. <copyrightNotice>
  [ 88] getlocal 4 .............................. <nScriptText>
  [ 90] joinstr ................................. <copyrightNotice & nScriptText>
  [ 91] pushcons 2 .............................. <RETURN>
  [ 93] joinstr ................................. <copyrightNotice & nScriptText & RETURN>
  [ 94] pushcons 2 .............................. <RETURN>
  [ 96] joinstr ................................. <copyrightNotice & nScriptText & RETURN & RETURN>
  [ 97] setlocal 4 .............................. nScriptText = copyrightNotice & nScriptText & RETURN & RETURN
  [ 99] getlocal 3 .............................. <nMember>
  [101] getlocal 4 .............................. <nScriptText>
  [103] setobjprop 4 ............................ nMember.scriptText = nScriptText
  [105] pushint8 1
  [107] getlocal 2
  [109] add
  [110] setlocal 2
  [112] endrepeat [ 22]
  [114] ret
end
