on VarInRange var, first, fin
  [  0] getparam 1 .............................. <first>
  [  2] pushsymb 73 ............................. <#list>
  [  4] pusharglist 2 ........................... <first, #list>
  [  6] extcall 69 .............................. <ilk(first, #list)>
  [  8] jmpifz [ 31] ............................ if ilk(first, #list) then
  [ 11] getparam 1 .............................. <first>
  [ 13] pushint8 2 .............................. <2>
  [ 15] pusharglist 2 ........................... <first, 2>
  [ 17] objcall 59 .............................. <first[2]>
  [ 19] setparam 2 .............................. fin = first[2]
  [ 21] getparam 1 .............................. <first>
  [ 23] pushint8 1 .............................. <1>
  [ 25] pusharglist 2 ........................... <first, 1>
  [ 27] objcall 59 .............................. <first[1]>
  [ 29] setparam 1 .............................. first = first[1]
  [ 31] getparam 0 .............................. <var>
  [ 33] getparam 1 .............................. <first>
  [ 35] getparam 2 .............................. <fin>
  [ 37] pusharglist 2 ........................... <first, fin>
  [ 39] extcall 140 ............................. <max(first, fin)>
  [ 41] pushint8 1 .............................. <1>
  [ 43] add ..................................... <max(first, fin) + 1>
  [ 44] lt ...................................... <var < (max(first, fin) + 1)>
  [ 45] getparam 0 .............................. <var>
  [ 47] getparam 1 .............................. <first>
  [ 49] getparam 2 .............................. <fin>
  [ 51] pusharglist 2 ........................... <first, fin>
  [ 53] extcall 141 ............................. <min(first, fin)>
  [ 55] pushint8 1 .............................. <1>
  [ 57] sub ..................................... <min(first, fin) - 1>
  [ 58] gt ...................................... <var > (min(first, fin) - 1)>
  [ 59] and ..................................... <(var < (max(first, fin) + 1)) and (var > (min(first, fin) - 1))>
  [ 60] jmpifz [ 70] ............................ if (var < (max(first, fin) + 1)) and (var > (min(first, fin) - 1)) then / else
  [ 63] pushint8 1 .............................. <1>
  [ 65] setlocal 0 .............................. inrange = 1
  [ 67] jmp [ 73]
  [ 70] pushzero ................................ <0>
  [ 71] setlocal 0 .............................. inrange = 0
  [ 73] getlocal 0 .............................. <inrange>
  [ 75] pusharglistnoret 1 ...................... <inrange>
  [ 77] extcall 24 .............................. return inrange
  [ 79] ret
end
