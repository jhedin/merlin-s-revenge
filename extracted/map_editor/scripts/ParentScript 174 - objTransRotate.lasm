  [ 13] setobjprop 911 .......................... params.initialValue = pSpr.rotation
  [ 16] getparam 0 .............................. <me>
  [ 18] getchainedprop 77 ....................... <me.ancestor>
  [ 20] getparam 1 .............................. <params>
  [ 22] pusharglistnoret 2 ...................... <me.ancestor, params>
  [ 24] objcall 1 ............................... me.ancestor.init(params)
  [ 26] getparam 0 .............................. <me>
  [ 28] pushint16 360 ........................... <360>
  [ 31] pusharglistnoret 2 ...................... <me, 360>
  [ 33] objcall 295 ............................. me.setTarget(360)
  [ 36] ret
end

on cancel me
  [  0] getprop 79 .............................. <pSpr>
  [  2] pushzero ................................ <0>
  [  3] setobjprop 1292 ......................... pSpr.rotation = 0
  [  6] getprop 77 .............................. <ancestor>
  [  8] pusharglistnoret 1 ...................... <ancestor>
  [ 10] objcall 431 ............................. ancestor.cancel()
  [ 13] ret
end

on finishConditionMet me
