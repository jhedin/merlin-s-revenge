  [ 58] pushzero ................................ <0>
  [ 59] pusharglistnoret 3 ...................... <obList, ob, 0>
  [ 61] objcall 37 .............................. obList[ob] = 0
  [ 63] pushint8 1
  [ 65] getlocal 1
  [ 67] add
  [ 68] setlocal 1
  [ 70] endrepeat [ 32]
  [ 72] pushint8 1
  [ 74] add
  [ 75] endrepeat [ 10]
  [ 77] pop 3
  [ 79] ret
end

on objFree me, id
  [  0] getparam 1 .............................. <id>
  [  2] getobjprop 63 ........................... <id.typ>
  [  4] setlocal 0 .............................. objSym = id.typ
  [  6] getparam 1 .............................. <id>
  [  8] getobjprop 64 ........................... <id.indx>
  [ 10] setlocal 1 .............................. indx = id.indx
  [ 12] getprop 20 .............................. <pStatusList>
  [ 14] getlocal 0 .............................. <objSym>
  [ 16] pusharglist 2 ........................... <pStatusList, objSym>
  [ 18] objcall 38 .............................. <pStatusList[objSym]>
  [ 20] getlocal 1 .............................. <indx>
  [ 22] pushzero ................................ <0>
  [ 23] pusharglistnoret 3 ...................... <pStatusList[objSym], indx, 0>
  [ 25] objcall 37 .............................. pStatusList[objSym][indx] = 0
  [ 27] ret
end

on objHasFlag me, theObj, theFlag
  [  0] getparam 1 .............................. <theObj>
  [  2] getchainedprop 69 ....................... <theObj.pFlags>
  [  4] getparam 2 .............................. <theFlag>
  [  6] pusharglist 2 ........................... <theObj.pFlags, theFlag>
  [  8] objcall 50 .............................. <theObj.pFlags.getPos(theFlag)>
  [ 10] pushzero ................................ <0>
  [ 11] gt ...................................... <theObj.pFlags.getPos(theFlag) > 0>
  [ 12] jmpifz [ 21] ............................ if theObj.pFlags.getPos(theFlag) > 0 then
  [ 15] pushint8 1 .............................. <1>
  [ 17] pusharglistnoret 1 ...................... <1>
  [ 19] extcall 17 .............................. return 1
  [ 21] pushzero ................................ <0>
  [ 22] pusharglistnoret 1 ...................... <0>
  [ 24] extcall 17 .............................. return 0
  [ 26] ret
end
