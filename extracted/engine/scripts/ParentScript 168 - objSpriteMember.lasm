  [  0] getprop 816 ............................. <pSprite>
  [  3] getparam 1 .............................. <therect>
  [  5] pusharglist 1 ........................... <therect>
  [  7] objcall 175 ............................. <therect.duplicate()>
  [  9] setobjprop 263 .......................... pSprite.rect = therect.duplicate()
