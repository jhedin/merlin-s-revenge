  [  2] pushint8 1 .............................. <1>
  [  4] eq ...................................... <thedir = 1>
  [  5] jmpifz [ 28] ............................ if thedir = 1 then / else
  [  8] getprop 816 ............................. <pSprite>
  [ 11] pushzero ................................ <0>
  [ 12] setobjprop 917 .......................... pSprite.flipH = 0
  [ 15] getparam 0 .............................. <me>
  [ 17] pushsymb 2343 ........................... <#topLeft>
  [ 20] pusharglistnoret 2 ...................... <me, #topLeft>
  [ 22] objcall 3123 ............................ me.setRegpoint(#topLeft)
  [ 25] jmp [ 55]
  [ 28] getparam 1 .............................. <thedir>
  [ 30] pushint8 1 .............................. <1>
  [ 32] inv ..................................... <-1>
  [ 33] eq ...................................... <thedir = -1>
  [ 34] jmpifz [ 55] ............................ if thedir = -1 then
  [ 37] getprop 816 ............................. <pSprite>
  [ 40] pushint8 1 .............................. <1>
  [ 42] setobjprop 917 .......................... pSprite.flipH = 1
  [ 45] getparam 0 .............................. <me>
  [ 47] pushsymb 2344 ........................... <#topRight>
  [ 50] pusharglistnoret 2 ...................... <me, #topRight>
  [ 52] objcall 3123 ............................ me.setRegpoint(#topRight)
  [ 55] ret
end

on setSpriteHeight me, newVal
  [  0] getprop 816 ............................. <pSprite>
  [  3] getparam 1 .............................. <newVal>
  [  5] setobjprop 423 .......................... pSprite.height = newVal
  [  8] ret
end

on setSpriteLocZ me, theLocZ
  [  0] getparam 0 .............................. <me>
  [  2] getparam 1 .............................. <theLocZ>
  [  4] pusharglistnoret 2 ...................... <me, theLocZ>
  [  6] objcall 2574 ............................ me.setSpriteLayer(theLocZ)
  [  9] ret
end

on setSpriteLayer me, theLayer
  [  0] getprop 816 ............................. <pSprite>
  [  3] getparam 1 .............................. <theLayer>
  [  5] setobjprop 259 .......................... pSprite.locZ = theLayer
  [  8] ret
end

on setSpriteLoc me, where
  [  0] getprop 816 ............................. <pSprite>
  [  3] pushsymb 49 ............................. <#none>
  [  5] nteq .................................... <pSprite <> #none>
  [  6] jmpifz [ 21] ............................ if pSprite <> #none then
  [  9] getprop 816 ............................. <pSprite>
  [ 12] getparam 1 .............................. <where>
  [ 14] pusharglist 1 ........................... <where>
  [ 16] objcall 175 ............................. <where.duplicate()>
  [ 18] setobjprop 832 .......................... pSprite.loc = where.duplicate()
  [ 21] ret
end

on setSpriteLocH me, where
  [  0] getprop 816 ............................. <pSprite>
  [  3] pushsymb 49 ............................. <#none>
  [  5] nteq .................................... <pSprite <> #none>
