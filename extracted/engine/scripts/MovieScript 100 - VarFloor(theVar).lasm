on VarFloor theVar
  [  0] getparam 0 .............................. <theVar>
  [  2] pushint16 1000 .......................... <1000>
  [  5] mul ..................................... <theVar * 1000>
  [  6] pusharglist 1 ........................... <theVar * 1000>
  [  8] extcall 346 ............................. <integer(theVar * 1000)>
  [ 11] setlocal 0 .............................. theInt = integer(theVar * 1000)
  [ 13] getlocal 0 .............................. <theInt>
  [ 15] pushint16 1000 .......................... <1000>
  [ 18] mod ..................................... <theInt mod 1000>
  [ 19] setlocal 1 .............................. theRemainder = theInt mod 1000
  [ 21] getlocal 0 .............................. <theInt>
  [ 23] getlocal 1 .............................. <theRemainder>
  [ 25] sub ..................................... <theInt - theRemainder>
  [ 26] setlocal 0 .............................. theInt = theInt - theRemainder
  [ 28] getlocal 0 .............................. <theInt>
  [ 30] pushint16 1000 .......................... <1000>
  [ 33] div ..................................... <theInt / 1000>
  [ 34] setlocal 0 .............................. theInt = theInt / 1000
  [ 36] getlocal 0 .............................. <theInt>
  [ 38] pusharglistnoret 1 ...................... <theInt>
  [ 40] extcall 3 ............................... return theInt
  [ 42] ret
end
