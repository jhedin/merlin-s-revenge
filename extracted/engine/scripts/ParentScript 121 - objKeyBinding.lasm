property ancestor

on new me
  [  0] pushcons 0 .............................. <"objTextData">
  [  2] pusharglist 1 ........................... <"objTextData">
  [  4] extcall 34 .............................. <script("objTextData")>
  [  6] pusharglist 1 ........................... <script("objTextData")>
  [  8] extcall 0 ............................... <new(script("objTextData"))>
  [ 10] setprop 33 .............................. ancestor = new(script("objTextData"))
  [ 12] getparam 0 .............................. <me>
  [ 14] pusharglistnoret 1 ...................... <me>
  [ 16] extcall 35 .............................. return me
  [ 18] ret
end
