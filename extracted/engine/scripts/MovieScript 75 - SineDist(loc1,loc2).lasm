on SineDist loc1, loc2
  [  0] getparam 0 .............................. <loc1>
  [  2] getparam 1 .............................. <loc2>
  [  4] sub ..................................... <loc1 - loc2>
  [  5] setlocal 0 .............................. distxy = loc1 - loc2
  [  7] getlocal 0 .............................. <distxy>
  [  9] getobjprop 158 .......................... <distxy.locH>
  [ 11] pushzero ................................ <0>
  [ 12] eq ...................................... <distxy.locH = 0>
  [ 13] jmpifz [ 31] ............................ if distxy.locH = 0 then / else
  [ 16] getlocal 0 .............................. <distxy>
  [ 18] getobjprop 159 .......................... <distxy.locV>
  [ 20] pushfloat32 1.0 ......................... <1.0>
  [ 25] mul ..................................... <distxy.locV * 1.0>
  [ 26] setlocal 1 .............................. dist = distxy.locV * 1.0
  [ 28] jmp [ 81]
  [ 31] getlocal 0 .............................. <distxy>
  [ 33] getobjprop 159 .......................... <distxy.locV>
  [ 35] getlocal 0 .............................. <distxy>
  [ 37] getobjprop 158 .......................... <distxy.locH>
  [ 39] div ..................................... <distxy.locV / distxy.locH>
  [ 40] pusharglist 1 ........................... <distxy.locV / distxy.locH>
  [ 42] extcall 144 ............................. <atan(distxy.locV / distxy.locH)>
  [ 44] setlocal 2 .............................. theta = atan(distxy.locV / distxy.locH)
  [ 46] getlocal 2 .............................. <theta>
  [ 48] pushzero ................................ <0>
  [ 49] eq ...................................... <theta = 0>
  [ 50] jmpifz [ 68] ............................ if theta = 0 then / else
  [ 53] getlocal 0 .............................. <distxy>
  [ 55] getobjprop 158 .......................... <distxy.locH>
  [ 57] pushfloat32 1.0 ......................... <1.0>
  [ 62] mul ..................................... <distxy.locH * 1.0>
  [ 63] setlocal 1 .............................. dist = distxy.locH * 1.0
  [ 65] jmp [ 81]
  [ 68] getlocal 0 .............................. <distxy>
  [ 70] getobjprop 159 .......................... <distxy.locV>
  [ 72] getlocal 2 .............................. <theta>
  [ 74] pusharglist 1 ........................... <theta>
  [ 76] extcall 183 ............................. <sin(theta)>
  [ 78] div ..................................... <distxy.locV / sin(theta)>
  [ 79] setlocal 1 .............................. dist = distxy.locV / sin(theta)
  [ 81] getlocal 1 .............................. <dist>
  [ 83] pushzero ................................ <0>
  [ 84] lt ...................................... <dist < 0>
  [ 85] jmpifz [ 93] ............................ if dist < 0 then
  [ 88] getlocal 1 .............................. <dist>
  [ 90] inv ..................................... <-dist>
  [ 91] setlocal 1 .............................. dist = -dist
  [ 93] getlocal 1 .............................. <dist>
  [ 95] pusharglistnoret 1 ...................... <dist>
  [ 97] extcall 3 ............................... return dist
  [ 99] ret
end
