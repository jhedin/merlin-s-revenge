  [ 26] objcall 1134 ............................ me.updateDisplay(pwizardsFound[pSelectedWizard].bar)
  [ 29] ret
end

on setWizards me, wizards
  [  0] getparam 1 .............................. <wizards>
  [  2] setprop 1664 ............................ pwizardsFound = wizards
