property pLoc, pWizardDisplayer, pwizardsFound, pSelectedWizard, pSummonMod
global g

on new me
  [  0] getparam 0 .............................. <me>
  [  2] pusharglistnoret 1 ...................... <me>
  [  4] extcall 3 ............................... return me
  [  6] ret
end

on init me
  [  0] pushzero ................................ <0>
  [  1] pushzero ................................ <0>
  [  2] pusharglist 2 ........................... <0, 0>
  [  4] extcall 122 ............................. <point(0, 0)>
  [  6] setprop 1135 ............................ pLoc = point(0, 0)
  [  9] pushsymb 103 ............................ <#none>
  [ 11] setprop 1663 ............................ pWizardDisplayer = #none
  [ 14] pusharglist 0 ........................... <[:]>
  [ 16] pushproplist ............................ <[:]>
  [ 17] setprop 1664 ............................ pwizardsFound = [:]
  [ 20] pushsymb 103 ............................ <#none>
  [ 22] setprop 1665 ............................ pSummonMod = #none
  [ 25] ret
end

on finish me
  [  0] getprop 1663 ............................ <pWizardDisplayer>
  [  3] pusharglist 1 ........................... <pWizardDisplayer>
  [  5] extcall 350 ............................. <ilk(pWizardDisplayer)>
  [  8] pushsymb 388 ............................ <#void>
  [ 11] nteq .................................... <ilk(pWizardDisplayer) <> #void>
  [ 12] getprop 1663 ............................ <pWizardDisplayer>
  [ 15] pushsymb 103 ............................ <#none>
  [ 17] nteq .................................... <pWizardDisplayer <> #none>
  [ 18] and ..................................... <(ilk(pWizardDisplayer) <> #void) and (pWizardDisplayer <> #none)>
  [ 19] jmpifz [ 34] ............................ if (ilk(pWizardDisplayer) <> #void) and (pWizardDisplayer <> #none) then
  [ 22] getprop 1663 ............................ <pWizardDisplayer>
  [ 25] pusharglistnoret 1 ...................... <pWizardDisplayer>
  [ 27] objcall 239 ............................. pWizardDisplayer.finish()
  [ 29] pushsymb 103 ............................ <#none>
  [ 31] setprop 1663 ............................ pWizardDisplayer = #none
  [ 34] ret
end

on newWizardFound me, theWizard
