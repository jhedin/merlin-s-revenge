  [ 71] objcall 54 .............................. pwizardsFound[wizardSym][#wizardSym] = wizardSym
  [ 73] getlocal 2 .............................. <wizardName>
  [ 75] pushcons 0 .............................. <"_off">
  [ 77] joinstr ................................. <wizardName & "_off">
  [ 78] setlocal 3 .............................. wizardBarPic = wizardName & "_off"
  [ 80] getprop 1664 ............................ <pwizardsFound>
  [ 83] getlocal 0 .............................. <wizardSym>
  [ 85] pusharglist 2 ........................... <pwizardsFound, wizardSym>
  [ 87] objcall 301 ............................. <pwizardsFound[wizardSym]>
  [ 90] pushsymb 1667 ........................... <#bar>
