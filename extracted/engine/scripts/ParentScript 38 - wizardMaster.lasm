  [ 95] pushcons 1 .............................. <"gfx">
  [ 97] pusharglist 2 ........................... <wizardBarPic, "gfx">
  [ 99] extcall 193 ............................. <member(wizardBarPic, "gfx")>
  [101] pusharglistnoret 3 ...................... <pwizardsFound[wizardSym], #bar, member(wizardBarPic, "gfx")>
  [103] objcall 1668 ............................ pwizardsFound[wizardSym].addProp(#bar, member(wizardBarPic, "gfx"))
  [106] getlocal 2 .............................. <wizardName>
  [108] pushcons 2 .............................. <"_ws">
  [110] joinstr ................................. <wizardName & "_ws">
  [111] setlocal 4 .............................. wizardSelectorPic = wizardName & "_ws"
  [113] getprop 1664 ............................ <pwizardsFound>
  [116] getlocal 0 .............................. <wizardSym>
  [118] pusharglist 2 ........................... <pwizardsFound, wizardSym>
  [120] objcall 301 ............................. <pwizardsFound[wizardSym]>
  [123] pushsymb 1669 ........................... <#selector>
  [126] getlocal 4 .............................. <wizardSelectorPic>
  [128] pushcons 1 .............................. <"gfx">
  [130] pusharglist 2 ........................... <wizardSelectorPic, "gfx">
  [132] extcall 193 ............................. <member(wizardSelectorPic, "gfx")>
  [134] pusharglistnoret 3 ...................... <pwizardsFound[wizardSym], #selector, member(wizardSelectorPic, "gfx")>
  [136] objcall 1668 ............................ pwizardsFound[wizardSym].addProp(#selector, member(wizardSelectorPic, "gfx"))
  [139] getprop 1664 ............................ <pwizardsFound>
  [142] getobjprop 348 .......................... <pwizardsFound.count>
  [145] pushint8 1 .............................. <1>
  [147] eq ...................................... <pwizardsFound.count = 1>
  [148] getprop 1665 ............................ <pSummonMod>
  [151] pushsymb 103 ............................ <#none>
  [153] nteq .................................... <pSummonMod <> #none>
  [154] and ..................................... <(pwizardsFound.count = 1) and (pSummonMod <> #none)>
  [155] jmpifz [193] ............................ if (pwizardsFound.count = 1) and (pSummonMod <> #none) then
  [158] getparam 0 .............................. <me>
  [160] getprop 1664 ............................ <pwizardsFound>
  [163] getlocal 0 .............................. <wizardSym>
  [165] pusharglist 2 ........................... <pwizardsFound, wizardSym>
  [167] objcall 301 ............................. <pwizardsFound[wizardSym]>
  [170] pusharglistnoret 2 ...................... <me, pwizardsFound[wizardSym]>
  [172] objcall 1659 ............................ me.setWizard(pwizardsFound[wizardSym])
  [175] getprop 1665 ............................ <pSummonMod>
  [178] getprop 1664 ............................ <pwizardsFound>
  [181] pusharglistnoret 2 ...................... <pSummonMod, pwizardsFound>
  [183] objcall 1670 ............................ pSummonMod.updateWizards(pwizardsFound)
  [186] getparam 0 .............................. <me>
  [188] pusharglistnoret 1 ...................... <me>
  [190] objcall 1661 ............................ me.wizardOn()
  [193] ret
end

on getWizards me
  [  0] getprop 1664 ............................ <pwizardsFound>
  [  3] pusharglist 1 ........................... <pwizardsFound>
  [  5] objcall 302 ............................. <pwizardsFound.duplicate()>
  [  8] pusharglistnoret 1 ...................... <pwizardsFound.duplicate()>
  [ 10] extcall 3 ............................... return pwizardsFound.duplicate()
  [ 12] ret
end

on registerMod me, theObj
  [  0] getparam 1 .............................. <theObj>
  [  2] setprop 1665 ............................ pSummonMod = theObj
  [  5] ret
end

on setWizard me, wizard
  [  0] getparam 1 .............................. <wizard>
  [  2] getobjprop 1666 ......................... <wizard.wizardSym>
  [  5] setprop 1676 ............................ pSelectedWizard = wizard.wizardSym
  [  8] getparam 0 .............................. <me>
  [ 10] getprop 1664 ............................ <pwizardsFound>
  [ 13] getprop 1676 ............................ <pSelectedWizard>
  [ 16] pusharglist 2 ........................... <pwizardsFound, pSelectedWizard>
  [ 18] objcall 301 ............................. <pwizardsFound[pSelectedWizard]>
  [ 21] getobjprop 1667 ......................... <pwizardsFound[pSelectedWizard].bar>
