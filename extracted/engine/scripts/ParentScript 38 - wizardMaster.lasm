  [  2] pusharglist 1 ........................... <theWizard>
  [  4] extcall 530 ............................. <string(theWizard)>
  [  7] setlocal 0 .............................. wizardSym = string(theWizard)
  [  9] getlocal 0 .............................. <wizardSym>
  [ 11] pushint8 1 .............................. <1>
  [ 13] get 1 ................................... <the number of chars in wizardSym>
  [ 15] setlocal 1 .............................. totalLength = the number of chars in wizardSym
  [ 17] getlocal 0 .............................. <wizardSym>
  [ 19] pushint8 1 .............................. <1>
  [ 21] getlocal 1 .............................. <totalLength>
  [ 23] pushint8 6 .............................. <6>
  [ 25] sub ..................................... <totalLength - 6>
  [ 26] pusharglist 3 ........................... <wizardSym, 1, totalLength - 6>
