  [ 31] setlocal 2 .............................. wizardName = chars(wizardSym, 1, totalLength - 6)
  [ 33] getlocal 2 .............................. <wizardName>
  [ 35] pusharglist 1 ........................... <wizardName>
  [ 37] extcall 442 ............................. <symbol(wizardName)>
  [ 40] setlocal 0 .............................. wizardSym = symbol(wizardName)
  [ 42] getprop 1664 ............................ <pwizardsFound>
  [ 45] getlocal 0 .............................. <wizardSym>
  [ 47] pusharglist 0 ........................... <[:]>
  [ 49] pushproplist ............................ <[:]>
  [ 50] pusharglistnoret 3 ...................... <pwizardsFound, wizardSym, [:]>
  [ 52] objcall 54 .............................. pwizardsFound[wizardSym] = [:]
  [ 54] getprop 1664 ............................ <pwizardsFound>
  [ 57] getlocal 0 .............................. <wizardSym>
  [ 59] pusharglist 2 ........................... <pwizardsFound, wizardSym>
