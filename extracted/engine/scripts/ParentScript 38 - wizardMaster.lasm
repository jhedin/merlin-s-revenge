end

on start me, theloc
  [  0] getparam 1 .............................. <theloc>
  [  2] setprop 1135 ............................ pLoc = theloc
  [  5] getglobal 191 ........................... <g>
  [  7] getchainedprop 336 ...................... <g.objectMaster>
  [ 10] pushsymb 1679 ........................... <#objWizardDisplayer>
  [ 13] pusharglist 2 ........................... <g.objectMaster, #objWizardDisplayer>
  [ 15] objcall 338 ............................. <g.objectMaster.requestObject(#objWizardDisplayer)>
  [ 18] setprop 1663 ............................ pWizardDisplayer = g.objectMaster.requestObject(#objWizardDisplayer)
  [ 21] getprop 1663 ............................ <pWizardDisplayer>
  [ 24] pushsymb 1 .............................. <#init>
  [ 26] pusharglist 2 ........................... <pWizardDisplayer, #init>
  [ 28] objcall 339 ............................. <pWizardDisplayer.getParams(#init)>
  [ 31] setlocal 0 .............................. params = pWizardDisplayer.getParams(#init)
  [ 33] getlocal 0 .............................. <params>
  [ 35] getparam 1 .............................. <theloc>
  [ 37] setobjprop 1138 ......................... params.displayLoc = theloc
  [ 40] getprop 1663 ............................ <pWizardDisplayer>
  [ 43] getlocal 0 .............................. <params>
  [ 45] pusharglistnoret 2 ...................... <pWizardDisplayer, params>
  [ 47] objcall 1 ............................... pWizardDisplayer.init(params)
  [ 49] ret
end

on stop me
  [  0] getparam 0 .............................. <me>
  [  2] pusharglistnoret 1 ...................... <me>
  [  4] objcall 239 ............................. me.finish()
  [  6] ret
end

