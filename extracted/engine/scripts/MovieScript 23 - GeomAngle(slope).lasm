  [ 46] getlocal 0 .............................. <deltaH>
  [ 48] pushzero ................................ <0>
  [ 49] lt ...................................... <deltaH < 0>
  [ 50] jmpifz [ 62] ............................ if deltaH < 0 then
  [ 53] getlocal 2 .............................. <angle>
