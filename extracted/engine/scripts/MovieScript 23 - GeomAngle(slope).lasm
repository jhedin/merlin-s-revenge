  [ 57] extcall 145 ............................. <PI>
  [ 59] add ..................................... <angle + PI>
  [ 60] setlocal 2 .............................. angle = angle + PI
  [ 62] jmp [109]
  [ 65] getlocal 1 .............................. <deltaV>
  [ 67] pushzero ................................ <0>
  [ 68] gt ...................................... <deltaV > 0>
  [ 69] jmpifz [ 84] ............................ if deltaV > 0 then / else
  [ 72] pusharglist 0 ........................... <>
  [ 74] extcall 145 ............................. <PI>
  [ 76] pushint8 2 .............................. <2>
  [ 78] div ..................................... <PI / 2>
