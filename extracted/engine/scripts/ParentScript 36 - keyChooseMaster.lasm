  [  2] getchainedprop 658 ...................... <g.collectionsMaster>
  [  5] pushsymb 430 ............................ <#objKeyDescriptions>
  [  8] pushsymb 281 ............................ <#all>
  [ 11] pusharglist 3 ........................... <g.collectionsMaster, #objKeyDescriptions, #all>
  [ 13] objcall 424 ............................. <g.collectionsMaster.getObject(#objKeyDescriptions, #all)>
  [ 16] setlocal 0 .............................. objData = g.collectionsMaster.getObject(#objKeyDescriptions, #all)
  [ 18] getlocal 0 .............................. <objData>
  [ 20] pusharglist 1 ........................... <objData>
  [ 22] objcall 931 ............................. <objData.getData()>
  [ 25] setprop 1597 ............................ pKeyDescriptions = objData.getData()
  [ 28] ret
end

on start me, myloc
  [  0] getparam 0 .............................. <me>
  [  2] getparam 1 .............................. <myloc>
  [  4] pusharglistnoret 2 ...................... <me, myloc>
