  [  9] getparam 0 .............................. <me>
  [ 11] pusharglistnoret 1 ...................... <me>
  [ 13] objcall 1586 ............................ me.retrieveCurrentKeySet()
  [ 16] getparam 0 .............................. <me>
  [ 18] pusharglistnoret 1 ...................... <me>
  [ 20] objcall 1584 ............................ me.displayCurrentKeySet()
  [ 23] ret
end

on startMenu me, theloc
  [  0] pushcons 76 ............................. <"dd_menu_keys">
  [  2] pushcons 1 .............................. <"gfx">
  [  4] pusharglist 2 ........................... <"dd_menu_keys", "gfx">
  [  6] extcall 193 ............................. <member("dd_menu_keys", "gfx")>
  [  8] setlocal 0 .............................. defMember = member("dd_menu_keys", "gfx")
  [ 10] getglobal 191 ........................... <g>
