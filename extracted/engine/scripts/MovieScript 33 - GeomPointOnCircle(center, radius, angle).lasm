on GeomPointOnCircle cent, rad, angl
  [  0] pushzero ................................ <0>
  [  1] pushzero ................................ <0>
  [  2] pusharglist 2 ........................... <0, 0>
  [  4] extcall 97 .............................. <point(0, 0)>
  [  6] setlocal 0 .............................. theloc = point(0, 0)
  [  8] getparam 2 .............................. <angl>
  [ 10] pushfloat32 180.0 ....................... <180.0>
  [ 15] div ..................................... <angl / 180.0>
  [ 16] pusharglist 0 ........................... <>
  [ 18] extcall 145 ............................. <PI>
  [ 20] mul ..................................... <angl / 180.0 * PI>
  [ 21] setlocal 1 .............................. radian = angl / 180.0 * PI
  [ 23] getlocal 0 .............................. <theloc>
  [ 25] pushint8 1 .............................. <1>
  [ 27] getparam 0 .............................. <cent>
  [ 29] pushint8 1 .............................. <1>
  [ 31] pusharglist 2 ........................... <cent, 1>
  [ 33] objcall 18 .............................. <cent[1]>
  [ 35] getlocal 1 .............................. <radian>
  [ 37] pusharglist 1 ........................... <radian>
  [ 39] extcall 182 ............................. <cos(radian)>
  [ 41] getparam 1 .............................. <rad>
  [ 43] mul ..................................... <cos(radian) * rad>
  [ 44] add ..................................... <cent[1] + (cos(radian) * rad)>
  [ 45] pusharglistnoret 3 ...................... <theloc, 1, cent[1] + (cos(radian) * rad)>
  [ 47] objcall 81 .............................. theloc[1] = cent[1] + (cos(radian) * rad)
  [ 49] getlocal 0 .............................. <theloc>
  [ 51] pushint8 2 .............................. <2>
  [ 53] getparam 0 .............................. <cent>
  [ 55] pushint8 2 .............................. <2>
  [ 57] pusharglist 2 ........................... <cent, 2>
  [ 59] objcall 18 .............................. <cent[2]>
  [ 61] getlocal 1 .............................. <radian>
  [ 63] pusharglist 1 ........................... <radian>
  [ 65] extcall 183 ............................. <sin(radian)>
  [ 67] getparam 1 .............................. <rad>
  [ 69] mul ..................................... <sin(radian) * rad>
  [ 70] sub ..................................... <cent[2] - (sin(radian) * rad)>
  [ 71] pusharglistnoret 3 ...................... <theloc, 2, cent[2] - (sin(radian) * rad)>
  [ 73] objcall 81 .............................. theloc[2] = cent[2] - (sin(radian) * rad)
  [ 75] getlocal 0 .............................. <theloc>
  [ 77] pusharglistnoret 1 ...................... <theloc>
  [ 79] extcall 3 ............................... return theloc
  [ 81] ret
end
