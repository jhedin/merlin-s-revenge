on VarPositive var
  [  0] getparam 0 .............................. <var>
  [  2] getparam 0 .............................. <var>
  [  4] pushint8 1 .............................. <1>
  [  6] inv ..................................... <-1>
  [  7] mul ..................................... <var * -1>
  [  8] pusharglist 2 ........................... <var, var * -1>
  [ 10] extcall 180 ............................. <max(var, var * -1)>
  [ 12] pusharglistnoret 1 ...................... <max(var, var * -1)>
  [ 14] extcall 3 ............................... return max(var, var * -1)
  [ 16] ret
end
