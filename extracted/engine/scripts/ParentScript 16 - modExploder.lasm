  [  4] getprop 639 ............................. <pExplodeSound>
  [  7] getprop 640 ............................. <pExplodeVolume>
  [ 10] pusharglistnoret 3 ...................... <me.big, pExplodeSound, pExplodeVolume>
  [ 12] objcall 551 ............................. me.big.PlaySound(pExplodeSound, pExplodeVolume)
  [ 15] getglobal 40 ............................ <g>
  [ 17] getchainedprop 642 ...................... <g.teamMaster>
  [ 20] getparam 0 .............................. <me>
  [ 22] getobjprop 51 ........................... <me.big>
