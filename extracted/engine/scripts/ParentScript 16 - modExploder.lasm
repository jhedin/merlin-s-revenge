  [ 20] getparam 0 .............................. <me>
  [ 22] pusharglistnoret 1 ...................... <me>
  [ 24] objcall 180 ............................. me.explode()
  [ 26] jmp [ 75]
  [ 29] getparam 1 .............................. <theEvent>
  [ 31] peek 0 .................................. case theEvent of
  [ 33] pushsymb 644 ............................ <#bulletCollidedWithTarget>
  [ 36] eq
  [ 37] jmpifz [ 52] ............................ (case) #bulletCollidedWithTarget:
  [ 40] getparam 0 .............................. <me>
  [ 42] getchainedprop 51 ....................... <me.big>
  [ 44] pusharglistnoret 1 ...................... <me.big>
  [ 46] objcall 501 ............................. me.big.die()
  [ 49] jmp [ 73]
  [ 52] peek 0
  [ 54] pushsymb 645 ............................ <#bulletLanded>
  [ 57] eq
  [ 58] jmpifz [ 73] ............................ (case) #bulletLanded:
  [ 61] getparam 0 .............................. <me>
