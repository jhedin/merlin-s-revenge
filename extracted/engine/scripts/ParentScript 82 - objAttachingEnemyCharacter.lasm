end

on loseEnergy me, amount
  [  0] getprop 33 .............................. <ancestor>
  [  2] getparam 1 .............................. <amount>
  [  4] pusharglistnoret 2 ...................... <ancestor, amount>
  [  6] objcall 511 ............................. ancestor.loseEnergy(amount)
  [  9] getparam 0 .............................. <me>
  [ 11] getobjprop 312 .......................... <me.pmode>
  [ 14] pushsymb 1957 ........................... <#attach>
  [ 17] eq ...................................... <me.pmode = #attach>
  [ 18] jmpifz [ 31] ............................ if me.pmode = #attach then
  [ 21] getparam 0 .............................. <me>
  [ 23] pushsymb 1055 ........................... <#reelFly>
  [ 26] pusharglistnoret 2 ...................... <me, #reelFly>
  [ 28] objcall 278 ............................. me.goMode(#reelFly)
  [ 31] ret
end

on checkCollisionsWithHair me
  [  0] getparam 0 .............................. <me>
  [  2] getobjprop 312 .......................... <me.pmode>
  [  5] peek 0 .................................. case me.pmode of
  [  7] pushsymb 1957 ........................... <#attach>
  [ 10] eq
  [ 11] jmpifz [ 20] ............................ (case) #attach:
  [ 14] pop 1
