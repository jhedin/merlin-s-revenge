end

on getAnimSym me, sym
  [  0] getparam 1 .............................. <sym>
  [  2] pushsymb 49 ............................. <#none>
  [  4] eq ...................................... <sym = #none>
  [  5] jmpifz [ 15] ............................ if sym = #none then
  [  8] getparam 0 .............................. <me>
  [ 10] getobjprop 312 .......................... <me.pmode>
  [ 13] setparam 1 .............................. sym = me.pmode
  [ 15] getparam 1 .............................. <sym>
  [ 17] peek 0 .................................. case sym of
  [ 19] pushsymb 1957 ........................... <#attach>
  [ 22] eq
  [ 23] jmpifz [ 33] ............................ (case) #attach:
  [ 26] pushsymb 69 ............................. <#stand>
  [ 28] setparam 1 .............................. sym = #stand
  [ 30] jmp [ 46]
  [ 33] peek 0
  [ 35] pushsymb 2066 ........................... <#attackObject>
  [ 38] eq
  [ 39] jmpifz [ 46] ............................ (case) #attackObject:
  [ 42] pushsymb 145 ............................ <#attack>
  [ 44] setparam 1 .............................. sym = #attack
  [ 46] pop 1 ................................... end case
  [ 48] getprop 33 .............................. <ancestor>
  [ 50] getparam 1 .............................. <sym>
  [ 52] pusharglist 2 ........................... <ancestor, sym>
  [ 54] objcall 10 .............................. <ancestor.getAnimSym(sym)>
