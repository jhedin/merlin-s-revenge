  [  7] ret
end

on getAcceleration me
  [  0] getprop 935 ............................. <pNavModeNormalAcceleration>
  [  3] pusharglistnoret 1 ...................... <pNavModeNormalAcceleration>
  [  5] extcall 35 .............................. return pNavModeNormalAcceleration
  [  7] ret
end

on goNavMode me
  [  0] getparam 0 .............................. <me>
  [  2] getchainedprop 57 ....................... <me.id>
  [  4] getchainedprop 58 ....................... <me.id.bigMe>
  [  6] getprop 933 ............................. <pNavModeAcceleration>
  [  9] pusharglistnoret 2 ...................... <me.id.bigMe, pNavModeAcceleration>
  [ 11] objcall 886 ............................. me.id.bigMe.setWalkAcceleration(pNavModeAcceleration)
  [ 14] pushint8 1 .............................. <1>
  [ 16] setprop 938 ............................. pNavModeActive = 1
  [ 19] ret
end

on leaveNavMode me
  [  0] getparam 0 .............................. <me>
  [  2] getchainedprop 57 ....................... <me.id>
  [  4] getchainedprop 58 ....................... <me.id.bigMe>
  [  6] getprop 935 ............................. <pNavModeNormalAcceleration>
  [  9] pusharglistnoret 2 ...................... <me.id.bigMe, pNavModeNormalAcceleration>
  [ 11] objcall 886 ............................. me.id.bigMe.setWalkAcceleration(pNavModeNormalAcceleration)
  [ 14] pushzero ................................ <0>
  [ 15] setprop 938 ............................. pNavModeActive = 0
  [ 18] ret
end

on incWalkAcceleration me, theType
  [  0] getparam 1 .............................. <theType>
  [  2] peek 0 .................................. case theType of
  [  4] pushsymb 939 ............................ <#potion>
  [  7] eq
  [  8] jmpifz [ 24] ............................ (case) #potion:
  [ 11] getprop 935 ............................. <pNavModeNormalAcceleration>
  [ 14] getprop 937 ............................. <pPotionAccelerationInc>
  [ 17] add ..................................... <pNavModeNormalAcceleration + pPotionAccelerationInc>
  [ 18] setprop 935 ............................. pNavModeNormalAcceleration = pNavModeNormalAcceleration + pPotionAccelerationInc
  [ 21] jmp [ 56]
  [ 24] peek 0
  [ 26] pushsymb 310 ............................ <#levelUp>
  [ 29] eq
  [ 30] jmpifz [ 46] ............................ (case) #levelUp:
  [ 33] getprop 935 ............................. <pNavModeNormalAcceleration>
  [ 36] getprop 936 ............................. <pWalkAccelerationInc>
  [ 39] add ..................................... <pNavModeNormalAcceleration + pWalkAccelerationInc>
  [ 40] setprop 935 ............................. pNavModeNormalAcceleration = pNavModeNormalAcceleration + pWalkAccelerationInc
  [ 43] jmp [ 56] ............................... (case) otherwise:
  [ 46] getprop 935 ............................. <pNavModeNormalAcceleration>
  [ 49] getprop 936 ............................. <pWalkAccelerationInc>
  [ 52] add ..................................... <pNavModeNormalAcceleration + pWalkAccelerationInc>
  [ 53] setprop 935 ............................. pNavModeNormalAcceleration = pNavModeNormalAcceleration + pWalkAccelerationInc
  [ 56] pop 1 ................................... end case
  [ 58] getparam 0 .............................. <me>
  [ 60] pusharglistnoret 1 ...................... <me>
  [ 62] objcall 932 ............................. me.implementChanges()
  [ 65] ret
end

on implementChanges me
  [  0] getprop 938 ............................. <pNavModeActive>
  [  3] pushzero ................................ <0>
  [  4] eq ...................................... <pNavModeActive = 0>
  [  5] jmpifz [ 15] ............................ if pNavModeActive = 0 then
  [  8] getparam 0 .............................. <me>
  [ 10] pusharglistnoret 1 ...................... <me>
  [ 12] objcall 790 ............................. me.leaveNavMode()
  [ 15] ret
end

on restoreFromSave me, sd
  [  0] getprop 33 .............................. <ancestor>
  [  2] getparam 1 .............................. <sd>
  [  4] pusharglistnoret 2 ...................... <ancestor, sd>
  [  6] objcall 26 .............................. ancestor.restoreFromSave(sd)
  [  8] getparam 1 .............................. <sd>
  [ 10] getobjprop 935 .......................... <sd.pNavModeNormalAcceleration>
  [ 13] setprop 935 ............................. pNavModeNormalAcceleration = sd.pNavModeNormalAcceleration
  [ 16] ret
end

