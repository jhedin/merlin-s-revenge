property ancestor, pNavModeAcceleration, pNavModeActive, pNavModeNormalAcceleration, pPotionAccelerationInc, pWalkAccelerationInc

on new me
  [  0] pushcons 0 .............................. <"modModule">
  [  2] pusharglist 1 ........................... <"modModule">
  [  4] extcall 34 .............................. <script("modModule")>
  [  6] pusharglist 1 ........................... <script("modModule")>
  [  8] extcall 0 ............................... <new(script("modModule"))>
  [ 10] setprop 33 .............................. ancestor = new(script("modModule"))
  [ 12] getparam 0 .............................. <me>
  [ 14] pusharglistnoret 1 ...................... <me>
  [ 16] extcall 35 .............................. return me
  [ 18] ret
end

on init me, params
  [  0] getparam 1 .............................. <params>
  [  2] getobjprop 934 .......................... <params.navModeAcceleration>
  [  5] setprop 933 ............................. pNavModeAcceleration = params.navModeAcceleration
  [  8] getparam 1 .............................. <params>
  [ 10] getobjprop 892 .......................... <params.walkAcceleration>
  [ 13] setprop 935 ............................. pNavModeNormalAcceleration = params.walkAcceleration
  [ 16] pushcons 1 .............................. <0.05>
  [ 18] setprop 936 ............................. pWalkAccelerationInc = 0.05
  [ 21] pushcons 2 .............................. <0.29999999999999999>
  [ 23] setprop 937 ............................. pPotionAccelerationInc = 0.29999999999999999
  [ 26] getprop 33 .............................. <ancestor>
  [ 28] getparam 1 .............................. <params>
  [ 30] pusharglistnoret 2 ...................... <ancestor, params>
  [ 32] objcall 1 ............................... ancestor.init(params)
  [ 34] ret
end

on addModParams me
  [  0] getparam 0 .............................. <me>
  [  2] pushsymb 1 .............................. <#init>
  [  4] pusharglist 2 ........................... <me, #init>
  [  6] objcall 47 .............................. <me.modifyParams(#init)>
  [  8] setlocal 0 .............................. i = me.modifyParams(#init)
  [ 10] getlocal 0 .............................. <i>
  [ 12] pushsymb 934 ............................ <#navModeAcceleration>
  [ 15] pushint8 6 .............................. <6>
  [ 17] pusharglistnoret 3 ...................... <i, #navModeAcceleration, 6>
  [ 19] objcall 48 .............................. i[#navModeAcceleration] = 6
  [ 21] getprop 33 .............................. <ancestor>
  [ 23] pusharglistnoret 1 ...................... <ancestor>
  [ 25] objcall 2 ............................... ancestor.addModParams()
  [ 27] ret
end

on addSaveData me, sd
  [  0] getprop 33 .............................. <ancestor>
  [  2] getparam 1 .............................. <sd>
  [  4] pusharglistnoret 2 ...................... <ancestor, sd>
  [  6] objcall 4 ............................... ancestor.addSaveData(sd)
  [  8] getparam 1 .............................. <sd>
  [ 10] pushsymb 935 ............................ <#pNavModeNormalAcceleration>
  [ 13] getprop 935 ............................. <pNavModeNormalAcceleration>
  [ 16] pusharglistnoret 3 ...................... <sd, #pNavModeNormalAcceleration, pNavModeNormalAcceleration>
  [ 18] objcall 48 .............................. sd[#pNavModeNormalAcceleration] = pNavModeNormalAcceleration
  [ 20] ret
end

on getNavModeActive me
  [  0] getprop 938 ............................. <pNavModeActive>
  [  3] pusharglistnoret 1 ...................... <pNavModeActive>
