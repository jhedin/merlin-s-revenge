  [ 24] getlocal 0 .............................. <commandSym>
  [ 26] pusharglistnoret 2 ...................... <pTarget, commandSym>
  [ 28] objcall 1627 ............................ pTarget.commandIssued(commandSym)
  [ 31] pop 1
  [ 33] ret
end

on setLocation me, newLoc
