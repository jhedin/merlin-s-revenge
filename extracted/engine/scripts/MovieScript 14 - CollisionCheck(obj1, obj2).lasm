  [ 63] jmpifz [ 71] ............................ if (obj1Rect = rect(-1, -1, 0, 0)) or (obj2RectInfo.rect = rect(-1, -1, 0, 0)) then
  [ 66] pushzero ................................ <0>
  [ 67] pusharglistnoret 1 ...................... <0>
  [ 69] extcall 3 ............................... return 0
