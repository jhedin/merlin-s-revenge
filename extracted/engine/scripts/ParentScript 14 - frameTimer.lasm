end

on waitFrame me, frameTime
  [  0] getprop 768 ............................. <pFrameLength>
  [  3] getparam 1 .............................. <frameTime>
  [  5] sub ..................................... <pFrameLength - frameTime>
  [  6] setlocal 0 .............................. extra = pFrameLength - frameTime
  [  8] getmovieprop 411 ........................ <the milliSeconds>
  [ 11] getlocal 0 .............................. <extra>
  [ 13] add ..................................... <the milliSeconds + extra>
  [ 14] setlocal 1 .............................. nFrameSecs = the milliSeconds + extra
  [ 16] getmovieprop 411 ........................ <the milliSeconds>
  [ 19] getlocal 1 .............................. <nFrameSecs>
  [ 21] lt ...................................... <the milliSeconds < nFrameSecs>
  [ 22] jmpifz [ 27] ............................ repeat while the milliSeconds < nFrameSecs
  [ 25] endrepeat [ 16]
  [ 27] getmovieprop 411 ........................ <the milliSeconds>
  [ 30] setprop 776 ............................. pLastTime = the milliSeconds
  [ 33] ret
end

on stop me
  [  0] getglobal 191 ........................... <g>
  [  2] getchainedprop 677 ...................... <g.updater>
  [  5] getparam 0 .............................. <me>
