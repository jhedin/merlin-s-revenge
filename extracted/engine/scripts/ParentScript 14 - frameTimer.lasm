end

on updateMaxTime me, currTime
  [  0] getprop 770 ............................. <pMaxTimeCount>
  [  3] pusharglistnoret 1 ...................... <pMaxTimeCount>
  [  5] extcall 255 ............................. counter(pMaxTimeCount)
  [  7] getprop 770 ............................. <pMaxTimeCount>
  [ 10] getobjprop 789 .......................... <pMaxTimeCount.fin>
  [ 13] jmpifz [ 21] ............................ if pMaxTimeCount.fin then
  [ 16] getparam 1 .............................. <currTime>
  [ 18] setprop 777 ............................. pMaxTime = currTime
  [ 21] getparam 1 .............................. <currTime>
  [ 23] getprop 777 ............................. <pMaxTime>
  [ 26] gt ...................................... <currTime > pMaxTime>
  [ 27] jmpifz [ 35] ............................ if currTime > pMaxTime then
  [ 30] getparam 1 .............................. <currTime>
  [ 32] setprop 777 ............................. pMaxTime = currTime
