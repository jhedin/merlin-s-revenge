global gMath

on VarFloorFlash theVar
  [  0] getglobal 515 ........................... <gMath>
  [  3] getparam 0 .............................. <theVar>
  [  5] pusharglist 2 ........................... <gMath, theVar>
  [  7] objcall 516 ............................. <gMath.floor(theVar)>
  [ 10] pusharglistnoret 1 ...................... <gMath.floor(theVar)>
  [ 12] extcall 3 ............................... return gMath.floor(theVar)
  [ 14] ret
end
