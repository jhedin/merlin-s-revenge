end

on removeLeadingSpaces me, theLine
  [  0] getparam 1 .............................. <theLine>
  [  2] pushsymb 1065 ........................... <#chars>
  [  5] pusharglist 2 ........................... <theLine, #chars>
  [  7] objcall 348 ............................. <theLine.chars.count>
  [ 10] setlocal 0 .............................. numChars = theLine.chars.count
  [ 12] pushzero ................................ <0>
  [ 13] setlocal 1 .............................. lastSpace = 0
  [ 15] pushint8 1 .............................. <1>
  [ 17] setlocal 2
  [ 19] getlocal 2
  [ 21] getlocal 0 .............................. <numChars>
  [ 23] lteq
  [ 24] jmpifz [ 68] ............................ repeat with i = 1 to numChars
  [ 27] getparam 1 .............................. <theLine>
  [ 29] pushsymb 439 ............................ <#char>
  [ 32] getlocal 2 .............................. <i>
  [ 34] pusharglist 3 ........................... <theLine, #char, i>
  [ 36] objcall 352 ............................. <theLine.char[i]>
  [ 39] setlocal 3 .............................. nChar = theLine.char[i]
  [ 41] getlocal 3 .............................. <nChar>
  [ 43] pushcons 8 .............................. <" ">
  [ 45] eq ...................................... <nChar = " ">
  [ 46] jmpifz [ 56] ............................ if nChar = " " then
  [ 49] getlocal 2 .............................. <i>
  [ 51] setlocal 1 .............................. lastSpace = i
  [ 53] jmp [ 59] ............................... next repeat
  [ 56] jmp [ 68] ............................... exit repeat
  [ 59] pushint8 1
  [ 61] getlocal 2
  [ 63] add
  [ 64] setlocal 2
  [ 66] endrepeat [ 19]
  [ 68] getlocal 1 .............................. <lastSpace>
  [ 70] pushzero ................................ <0>
  [ 71] gt ...................................... <lastSpace > 0>
  [ 72] jmpifz [ 94] ............................ if lastSpace > 0 then
  [ 75] getparam 1 .............................. <theLine>
  [ 77] pushsymb 439 ............................ <#char>
  [ 80] getlocal 1 .............................. <lastSpace>
  [ 82] pushint8 1 .............................. <1>
  [ 84] add ..................................... <lastSpace + 1>
  [ 85] pushint8 99 ............................. <99>
  [ 87] pusharglist 4 ........................... <theLine, #char, lastSpace + 1, 99>
  [ 89] objcall 352 ............................. <theLine.char[lastSpace + 1..99]>
  [ 92] setparam 1 .............................. theLine = theLine.char[lastSpace + 1..99]
  [ 94] getparam 1 .............................. <theLine>
  [ 96] pusharglistnoret 1 ...................... <theLine>
  [ 98] extcall 3 ............................... return theLine
  [100] ret
end

on stop me
  [  0] ret
end
