  [  2] setlocal 0 .............................. XML = EMPTY
  [  4] getparam 1 .............................. <theValue>
  [  6] pushsymb 1062 ........................... <#linearList>
  [  9] pusharglist 2 ........................... <theValue, #linearList>
  [ 11] extcall 350 ............................. <ilk(theValue, #linearList)>
  [ 14] jmpifz [154] ............................ if ilk(theValue, #linearList) then / else
  [ 17] pushint8 1 .............................. <1>
  [ 19] setlocal 1 .............................. i = 1
  [ 21] getparam 1 .............................. <theValue>
  [ 23] peek 0
  [ 25] pusharglist 1
  [ 27] extcall 348
  [ 30] pushint8 1
  [ 32] peek 0
  [ 34] peek 2
  [ 36] lteq
  [ 37] jmpifz [149] ............................ repeat with itm in theValue
  [ 40] peek 2
  [ 42] peek 1
  [ 44] pusharglist 2
  [ 46] extcall 301
  [ 49] setlocal 2
  [ 51] getlocal 2 .............................. <itm>
  [ 53] pushsymb 1056 ........................... <#propList>
  [ 56] pusharglist 2 ........................... <itm, #propList>
  [ 58] extcall 350 ............................. <ilk(itm, #propList)>
  [ 61] jmpifz [123] ............................ if ilk(itm, #propList) then / else
  [ 64] getlocal 1 .............................. <i>
  [ 66] pushint8 1 .............................. <1>
  [ 68] gt ...................................... <i > 1>
  [ 69] jmpifz [106] ............................ if i > 1 then
  [ 72] getlocal 0 .............................. <XML>
  [ 74] pushcons 3 .............................. <"</">
  [ 76] joinstr ................................. <XML & "</">
  [ 77] getparam 2 .............................. <theTag>
  [ 79] joinstr ................................. <XML & "</" & theTag>
  [ 80] pushcons 4 .............................. <">">
  [ 82] joinstr ................................. <XML & "</" & theTag & ">">
  [ 83] getglobal 259 ........................... <r>
  [ 86] joinstr ................................. <XML & "</" & theTag & ">" & r>
  [ 87] setlocal 0 .............................. XML = XML & "</" & theTag & ">" & r
  [ 89] getlocal 0 .............................. <XML>
  [ 91] pushcons 5 .............................. <"<">
  [ 93] joinstr ................................. <XML & "<">
  [ 94] getparam 2 .............................. <theTag>
  [ 96] joinstr ................................. <XML & "<" & theTag>
  [ 97] pushcons 4 .............................. <">">
  [ 99] joinstr ................................. <XML & "<" & theTag & ">">
  [100] getglobal 259 ........................... <r>
  [103] joinstr ................................. <XML & "<" & theTag & ">" & r>
  [104] setlocal 0 .............................. XML = XML & "<" & theTag & ">" & r
  [106] getlocal 0 .............................. <XML>
  [108] getparam 0 .............................. <me>
  [110] getlocal 2 .............................. <itm>
  [112] pusharglist 2 ........................... <me, itm>
  [114] objcall 1023 ............................ <me.XMLFromPropList(itm)>
  [117] joinstr ................................. <XML & me.XMLFromPropList(itm)>
  [118] setlocal 0 .............................. XML = XML & me.XMLFromPropList(itm)
  [120] jmp [137]
  [123] getlocal 0 .............................. <XML>
  [125] getparam 0 .............................. <me>
  [127] getlocal 2 .............................. <itm>
  [129] pusharglist 2 ........................... <me, itm>
  [131] objcall 1024 ............................ <me.XMLItem(itm)>
  [134] joinstr ................................. <XML & me.XMLItem(itm)>
  [135] setlocal 0 .............................. XML = XML & me.XMLItem(itm)
  [137] getlocal 1 .............................. <i>
  [139] pushint8 1 .............................. <1>
  [141] add ..................................... <i + 1>
  [142] setlocal 1 .............................. i = i + 1
  [144] pushint8 1
  [146] add
  [147] endrepeat [ 32]
  [149] pop 3
  [151] jmp [168]
  [154] getlocal 0 .............................. <XML>
  [156] getparam 0 .............................. <me>
  [158] getparam 1 .............................. <theValue>
  [160] pusharglist 2 ........................... <me, theValue>
  [162] objcall 1024 ............................ <me.XMLItem(theValue)>
  [165] joinstr ................................. <XML & me.XMLItem(theValue)>
  [166] setlocal 0 .............................. XML = XML & me.XMLItem(theValue)
  [168] getlocal 0 .............................. <XML>
  [170] pusharglistnoret 1 ...................... <XML>
