  [ 10] setprop 33 .............................. ancestor = new(script("objAutoUpdate"))
  [ 12] getparam 0 .............................. <me>
  [ 14] pushsymb 1 .............................. <#init>
  [ 16] pusharglist 2 ........................... <me, #init>
  [ 18] objcall 47 .............................. <me.modifyParams(#init)>
  [ 20] setlocal 0 .............................. i = me.modifyParams(#init)
  [ 22] getlocal 0 .............................. <i>
  [ 24] pushsymb 474 ............................ <#callingPrg>
  [ 27] pushsymb 49 ............................. <#none>
  [ 29] pusharglistnoret 3 ...................... <i, #callingPrg, #none>
  [ 31] objcall 48 .............................. i[#callingPrg] = #none
  [ 33] getlocal 0 .............................. <i>
  [ 35] pushsymb 267 ............................ <#spr>
  [ 38] pushsymb 49 ............................. <#none>
  [ 40] pusharglistnoret 3 ...................... <i, #spr, #none>
  [ 42] objcall 48 .............................. i[#spr] = #none
  [ 44] getlocal 0 .............................. <i>
  [ 46] pushsymb 716 ............................ <#time>
  [ 49] pushint8 10 ............................. <10>
