  [ 61] ret
end

on init me, params
  [  0] pusharglist 0 ........................... <>
  [  2] extcall 529 ............................. <CounterNew()>
  [  5] setprop 2653 ............................ pTimeCounter = CounterNew()
  [  8] getparam 1 .............................. <params>
  [ 10] getchainedprop 474 ...................... <params.callingPrg>
  [ 13] getchainedprop 57 ....................... <params.callingPrg.id>
  [ 15] getobjprop 58 ........................... <params.callingPrg.id.bigMe>
  [ 17] setprop 2081 ............................ pCallingPrg = params.callingPrg.id.bigMe
  [ 20] getparam 1 .............................. <params>
  [ 22] getobjprop 267 .......................... <params.spr>
  [ 25] setprop 173 ............................. pSpr = params.spr
  [ 27] getprop 2653 ............................ <pTimeCounter>
  [ 30] pushsymb 530 ............................ <#tim>
  [ 33] pushint8 2 .............................. <2>
  [ 35] getparam 1 .............................. <params>
  [ 37] getobjprop 716 .......................... <params.time>
  [ 40] pusharglistnoret 4 ...................... <pTimeCounter, #tim, 2, params.time>
  [ 42] objcall 531 ............................. pTimeCounter.tim[2] = params.time
  [ 45] getprop 2653 ............................ <pTimeCounter>
  [ 48] pusharglistnoret 1 ...................... <pTimeCounter>
