end

on setCallingPrg me, newVal
  [  0] getparam 1 .............................. <newVal>
  [  2] setprop 2081 ............................ pCallingPrg = newVal
  [  5] ret
end

on setSprite me, newSpr
  [  0] getparam 1 .............................. <newSpr>
  [  2] setprop 173 ............................. pSpr = newSpr
  [  4] ret
end

on update me
  [  0] getprop 173 ............................. <pSpr>
  [  2] getobjprop 687 .......................... <pSpr.blend>
  [  5] pushzero ................................ <0>
  [  6] eq ...................................... <pSpr.blend = 0>
