  [  3] pusharglistnoret 1 ...................... <pCallingPrg>
  [  5] objcall 710 ............................. pCallingPrg.flasherFinished()
  [  8] ret
end

on restoreFromSave me, sd
  [  0] getprop 33 .............................. <ancestor>
  [  2] getparam 1 .............................. <sd>
  [  4] pusharglistnoret 2 ...................... <ancestor, sd>
  [  6] objcall 26 .............................. ancestor.restoreFromSave(sd)
  [  8] getparam 1 .............................. <sd>
  [ 10] getobjprop 2653 ......................... <sd.pTimeCounter>
  [ 13] setprop 2653 ............................ pTimeCounter = sd.pTimeCounter
