  [ 53] getparam 0 .............................. <me>
  [ 55] getchainedprop 33 ....................... <me.ancestor>
  [ 57] getparam 1 .............................. <params>
  [ 59] pusharglistnoret 2 ...................... <me.ancestor, params>
  [ 61] objcall 1 ............................... me.ancestor.init(params)
  [ 63] getparam 0 .............................. <me>
  [ 65] pusharglistnoret 1 ...................... <me>
  [ 67] objcall 692 ............................. me.calcStart()
  [ 70] ret
end

on addSaveData me, sd
  [  0] getprop 33 .............................. <ancestor>
  [  2] getparam 1 .............................. <sd>
  [  4] pusharglistnoret 2 ...................... <ancestor, sd>
  [  6] objcall 4 ............................... ancestor.addSaveData(sd)
  [  8] getparam 1 .............................. <sd>
  [ 10] pushsymb 2653 ........................... <#pTimeCounter>
  [ 13] getprop 2653 ............................ <pTimeCounter>
  [ 16] pusharglistnoret 3 ...................... <sd, #pTimeCounter, pTimeCounter>
  [ 18] objcall 48 .............................. sd[#pTimeCounter] = pTimeCounter
  [ 20] ret
end

on finish me
  [  0] pushsymb 49 ............................. <#none>
  [  2] setprop 173 ............................. pSpr = #none
  [  4] getprop 33 .............................. <ancestor>
  [  6] pusharglistnoret 1 ...................... <ancestor>
  [  8] objcall 3 ............................... ancestor.finish()
  [ 10] ret
end

on finishConditionMet me
  [  0] getprop 2653 ............................ <pTimeCounter>
  [  3] getobjprop 552 .......................... <pTimeCounter.fin>
  [  6] pusharglistnoret 1 ...................... <pTimeCounter.fin>
  [  8] extcall 35 .............................. return pTimeCounter.fin
  [ 10] ret
end

on informCallingPrg me
