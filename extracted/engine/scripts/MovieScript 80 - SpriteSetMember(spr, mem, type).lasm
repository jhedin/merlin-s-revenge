on SpriteSetMember spr, mem, type, keepSize
  [  0] getparam 2 .............................. <type>
  [  2] pusharglist 0 ........................... <>
  [  4] extcall 26 .............................. <VOID>
  [  6] eq ...................................... <type = VOID>
  [  7] jmpifz [ 15] ............................ if type = VOID then
  [ 10] pushsymb 401 ............................ <#gameChar>
  [ 13] setparam 2 .............................. type = #gameChar
  [ 15] getparam 3 .............................. <keepSize>
  [ 17] pusharglist 0 ........................... <>
  [ 19] extcall 26 .............................. <VOID>
  [ 21] eq ...................................... <keepSize = VOID>
  [ 22] jmpifz [ 28] ............................ if keepSize = VOID then
  [ 25] pushzero ................................ <0>
  [ 26] setparam 3 .............................. keepSize = 0
  [ 28] getparam 2 .............................. <type>
  [ 30] peek 0 .................................. case type of
  [ 32] pushsymb 401 ............................ <#gameChar>
  [ 35] eq
  [ 36] jmpifz [121] ............................ (case) #gameChar:
  [ 39] getparam 0 .............................. <spr>
  [ 41] getparam 1 .............................. <mem>
  [ 43] setobjprop 34 ........................... spr.member = mem
  [ 45] getparam 3 .............................. <keepSize>
  [ 47] pushzero ................................ <0>
  [ 48] eq ...................................... <keepSize = 0>
  [ 49] jmpifz [ 68] ............................ if keepSize = 0 then
  [ 52] getparam 0 .............................. <spr>
  [ 54] getparam 1 .............................. <mem>
  [ 56] getobjprop 190 .......................... <mem.width>
  [ 58] setobjprop 190 .......................... spr.width = mem.width
  [ 60] getparam 0 .............................. <spr>
  [ 62] getparam 1 .............................. <mem>
  [ 64] getobjprop 191 .......................... <mem.height>
  [ 66] setobjprop 191 .......................... spr.height = mem.height
  [ 68] getparam 0 .............................. <spr>
  [ 70] getchainedprop 34 ....................... <spr.member>
  [ 72] getobjprop 1 ............................ <spr.member.type>
  [ 74] pushsymb 402 ............................ <#bitmap>
  [ 77] eq ...................................... <spr.member.type = #bitmap>
  [ 78] jmpifz [112] ............................ if spr.member.type = #bitmap then / else
  [ 81] getparam 0 .............................. <spr>
  [ 83] getchainedprop 34 ....................... <spr.member>
  [ 85] getobjprop 403 .......................... <spr.member.depth>
  [ 88] pushint8 1 .............................. <1>
  [ 90] eq ...................................... <spr.member.depth = 1>
  [ 91] jmpifz [103] ............................ if spr.member.depth = 1 then / else
  [ 94] getparam 0 .............................. <spr>
  [ 96] pushint8 1 .............................. <1>
  [ 98] setobjprop 195 .......................... spr.ink = 1
  [100] jmp [109]
  [103] getparam 0 .............................. <spr>
  [105] pushint8 36 ............................. <36>
  [107] setobjprop 195 .......................... spr.ink = 36
  [109] jmp [118]
  [112] getparam 0 .............................. <spr>
  [114] pushint8 36 ............................. <36>
  [116] setobjprop 195 .......................... spr.ink = 36
  [118] jmp [141]
  [121] peek 0
  [123] pushsymb 404 ............................ <#field>
  [126] eq
  [127] jmpifz [141] ............................ (case) #field:
  [130] getparam 0 .............................. <spr>
  [132] getparam 1 .............................. <mem>
  [134] setobjprop 34 ........................... spr.member = mem
  [136] getparam 0 .............................. <spr>
  [138] pushzero ................................ <0>
  [139] setobjprop 195 .......................... spr.ink = 0
  [141] pop 1 ................................... end case
  [143] ret
end
