property ancestor, pMusicName
global g

on new me
  [  0] pushcons 0 .............................. <"objGameObject">
  [  2] pusharglist 1 ........................... <"objGameObject">
  [  4] extcall 34 .............................. <script("objGameObject")>
  [  6] pusharglist 1 ........................... <script("objGameObject")>
  [  8] extcall 0 ............................... <new(script("objGameObject"))>
  [ 10] setprop 33 .............................. ancestor = new(script("objGameObject"))
  [ 12] getparam 0 .............................. <me>
  [ 14] pushsymb 1 .............................. <#init>
  [ 16] pusharglist 2 ........................... <me, #init>
  [ 18] objcall 47 .............................. <me.modifyParams(#init)>
  [ 20] setlocal 0 .............................. i = me.modifyParams(#init)
  [ 22] getlocal 0 .............................. <i>
  [ 24] pushsymb 3449 ........................... <#musicName>
  [ 27] pushsymb 49 ............................. <#none>
  [ 29] pusharglistnoret 3 ...................... <i, #musicName, #none>
  [ 31] objcall 48 .............................. i[#musicName] = #none
  [ 33] getparam 0 .............................. <me>
  [ 35] pushcons 1 .............................. <"modAnimSet">
  [ 37] pusharglistnoret 2 ...................... <me, "modAnimSet">
  [ 39] objcall 1717 ............................ me.addModule("modAnimSet")
  [ 42] getparam 0 .............................. <me>
  [ 44] pusharglistnoret 1 ...................... <me>
  [ 46] extcall 35 .............................. return me
  [ 48] ret
end

on init me, params
  [  0] getprop 33 .............................. <ancestor>
  [  2] getparam 1 .............................. <params>
  [  4] pusharglistnoret 2 ...................... <ancestor, params>
  [  6] objcall 1 ............................... ancestor.init(params)
  [  8] getparam 1 .............................. <params>
  [ 10] getobjprop 3449 ......................... <params.musicName>
  [ 13] setprop 3450 ............................ pMusicName = params.musicName
  [ 16] ret
end

on start me
  [  0] getprop 33 .............................. <ancestor>
  [  2] pusharglistnoret 1 ...................... <ancestor>
  [  4] objcall 1590 ............................ ancestor.start()
  [  7] getglobal 40 ............................ <g>
  [  9] getchainedprop 1268 ..................... <g.soundmaster>
  [ 12] getprop 3450 ............................ <pMusicName>
  [ 15] pusharglistnoret 2 ...................... <g.soundmaster, pMusicName>
  [ 17] objcall 3451 ............................ g.soundmaster.playMusic(pMusicName)
  [ 20] ret
end
