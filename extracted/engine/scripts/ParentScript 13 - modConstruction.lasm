property ancestor, pIsBuilt, pPercentToAddPerFrame, pPreBuilt

on new me
  [  0] pushcons 0 .............................. <"modModule">
  [  2] pusharglist 1 ........................... <"modModule">
  [  4] extcall 34 .............................. <script("modModule")>
  [  6] pusharglist 1 ........................... <script("modModule")>
  [  8] extcall 0 ............................... <new(script("modModule"))>
  [ 10] setprop 33 .............................. ancestor = new(script("modModule"))
  [ 12] getparam 0 .............................. <me>
  [ 14] pusharglistnoret 1 ...................... <me>
  [ 16] extcall 35 .............................. return me
  [ 18] ret
end

on addModParams me
  [  0] getparam 0 .............................. <me>
  [  2] pushsymb 1 .............................. <#init>
  [  4] pusharglist 2 ........................... <me, #init>
  [  6] objcall 47 .............................. <me.modifyParams(#init)>
  [  8] setlocal 0 .............................. i = me.modifyParams(#init)
  [ 10] getlocal 0 .............................. <i>
  [ 12] pushsymb 487 ............................ <#preBuilt>
  [ 15] pushint8 1 .............................. <1>
  [ 17] pusharglistnoret 3 ...................... <i, #preBuilt, 1>
  [ 19] objcall 48 .............................. i[#preBuilt] = 1
  [ 21] getprop 33 .............................. <ancestor>
  [ 23] pusharglistnoret 1 ...................... <ancestor>
  [ 25] objcall 2 ............................... ancestor.addModParams()
  [ 27] ret
end

on init me, params
  [  0] getprop 33 .............................. <ancestor>
  [  2] getparam 1 .............................. <params>
  [  4] pusharglistnoret 2 ...................... <ancestor, params>
  [  6] objcall 1 ............................... ancestor.init(params)
  [  8] pushzero ................................ <0>
  [  9] setprop 488 ............................. pIsBuilt = 0
  [ 12] pushzero ................................ <0>
  [ 13] setprop 489 ............................. pPercentToAddPerFrame = 0
  [ 16] getparam 1 .............................. <params>
  [ 18] getobjprop 487 .......................... <params.preBuilt>
  [ 21] setprop 490 ............................. pPreBuilt = params.preBuilt
  [ 24] ret
end

on addSaveData me, sd
  [  0] getprop 33 .............................. <ancestor>
  [  2] getparam 1 .............................. <sd>
  [  4] pusharglistnoret 2 ...................... <ancestor, sd>
  [  6] objcall 4 ............................... ancestor.addSaveData(sd)
  [  8] getparam 1 .............................. <sd>
  [ 10] pushsymb 488 ............................ <#pIsBuilt>
  [ 13] getprop 488 ............................. <pIsBuilt>
  [ 16] pusharglistnoret 3 ...................... <sd, #pIsBuilt, pIsBuilt>
  [ 18] objcall 48 .............................. sd[#pIsBuilt] = pIsBuilt
  [ 20] getparam 1 .............................. <sd>
  [ 22] pushsymb 489 ............................ <#pPercentToAddPerFrame>
  [ 25] getprop 489 ............................. <pPercentToAddPerFrame>
  [ 28] pusharglistnoret 3 ...................... <sd, #pPercentToAddPerFrame, pPercentToAddPerFrame>
  [ 30] objcall 48 .............................. sd[#pPercentToAddPerFrame] = pPercentToAddPerFrame
  [ 32] ret
end

on advanceBuildFrame me
  [  0] getparam 0 .............................. <me>
  [  2] getchainedprop 51 ....................... <me.big>
  [  4] pusharglistnoret 1 ...................... <me.big>
  [  6] objcall 7 ............................... me.big.frameAdvance()
  [  8] getparam 0 .............................. <me>
  [ 10] getchainedprop 51 ....................... <me.big>
  [ 12] getprop 489 ............................. <pPercentToAddPerFrame>
  [ 15] pusharglistnoret 2 ...................... <me.big, pPercentToAddPerFrame>
  [ 17] objcall 491 ............................. me.big.increaseEnergyByPercentage(pPercentToAddPerFrame)
  [ 20] getparam 0 .............................. <me>
  [ 22] getchainedprop 51 ....................... <me.big>
  [ 24] pusharglist 1 ........................... <me.big>
  [ 26] objcall 16 .............................. <me.big.getAnimLooped()>
  [ 28] jmpifz [ 38] ............................ if me.big.getAnimLooped() then
  [ 31] getparam 0 .............................. <me>
  [ 33] pusharglistnoret 1 ...................... <me>
  [ 35] objcall 482 ............................. me.buildingFinished()
  [ 38] ret
end

on buildingFinished me
  [  0] pushint8 1 .............................. <1>
  [  2] setprop 488 ............................. pIsBuilt = 1
  [  5] getparam 0 .............................. <me>
  [  7] getchainedprop 51 ....................... <me.big>
  [  9] pushsymb 69 ............................. <#stand>
  [ 11] pusharglistnoret 2 ...................... <me.big, #stand>
  [ 13] objcall 492 ............................. me.big.setMode(#stand)
  [ 16] getparam 0 .............................. <me>
  [ 18] getchainedprop 51 ....................... <me.big>
  [ 20] pusharglistnoret 1 ...................... <me.big>
  [ 22] objcall 30 .............................. me.big.unpauseAnim()
  [ 24] getparam 0 .............................. <me>
  [ 26] getchainedprop 51 ....................... <me.big>
  [ 28] pushsymb 482 ............................ <#buildingFinished>
  [ 31] pusharglistnoret 2 ...................... <me.big, #buildingFinished>
  [ 33] objcall 22 .............................. me.big.internalEvent(#buildingFinished)
  [ 35] getparam 0 .............................. <me>
  [ 37] pushsymb 482 ............................ <#buildingFinished>
  [ 40] pusharglistnoret 2 ...................... <me, #buildingFinished>
  [ 42] objcall 123 ............................. me.eventNotify(#buildingFinished)
  [ 44] ret
end

on isUnfinishedBuilding me
  [  0] getprop 488 ............................. <pIsBuilt>
  [  3] pushint8 1 .............................. <1>
  [  5] eq ...................................... <pIsBuilt = 1>
  [  6] jmpifz [ 17] ............................ if pIsBuilt = 1 then / else
  [  9] pushzero ................................ <0>
  [ 10] pusharglistnoret 1 ...................... <0>
  [ 12] extcall 35 .............................. return 0
  [ 14] jmp [ 23]
  [ 17] pushint8 1 .............................. <1>
  [ 19] pusharglistnoret 1 ...................... <1>
  [ 21] extcall 35 .............................. return 1
  [ 23] ret
end

on outOfEnergy me
  [  0] getprop 33 .............................. <ancestor>
  [  2] pusharglistnoret 1 ...................... <ancestor>
  [  4] objcall 484 ............................. ancestor.outOfEnergy()
  [  7] getparam 0 .............................. <me>
  [  9] getchainedprop 51 ....................... <me.big>
  [ 11] pusharglistnoret 1 ...................... <me.big>
  [ 13] objcall 30 .............................. me.big.unpauseAnim()
  [ 15] ret
end

on goMode me, newMode
  [  0] getparam 1 .............................. <newMode>
  [  2] peek 0 .................................. case newMode of
  [  4] pushsymb 493 ............................ <#beBuilt>
  [  7] eq
  [  8] jmpifz [ 18] ............................ (case) #beBuilt:
  [ 11] getparam 0 .............................. <me>
  [ 13] pusharglistnoret 1 ...................... <me>
  [ 15] objcall 485 ............................. me.startBeBuilt()
  [ 18] pop 1
  [ 20] getprop 33 .............................. <ancestor>
  [ 22] getparam 1 .............................. <newMode>
  [ 24] pusharglistnoret 2 ...................... <ancestor, newMode>
  [ 26] objcall 278 ............................. ancestor.goMode(newMode)
  [ 29] ret
end

on restoreFromSave me, sd
  [  0] getprop 33 .............................. <ancestor>
  [  2] getparam 1 .............................. <sd>
  [  4] pusharglistnoret 2 ...................... <ancestor, sd>
  [  6] objcall 26 .............................. ancestor.restoreFromSave(sd)
  [  8] getparam 1 .............................. <sd>
  [ 10] getobjprop 488 .......................... <sd.pIsBuilt>
  [ 13] setprop 488 ............................. pIsBuilt = sd.pIsBuilt
  [ 16] getparam 1 .............................. <sd>
  [ 18] getobjprop 489 .......................... <sd.pPercentToAddPerFrame>
  [ 21] setprop 489 ............................. pPercentToAddPerFrame = sd.pPercentToAddPerFrame
  [ 24] ret
end

on startBeBuilt me
  [  0] getparam 0 .............................. <me>
  [  2] getchainedprop 51 ....................... <me.big>
  [  4] pusharglistnoret 1 ...................... <me.big>
  [  6] objcall 23 .............................. me.big.pauseAnim()
  [  8] getparam 0 .............................. <me>
  [ 10] getchainedprop 51 ....................... <me.big>
  [ 12] pushint8 1 .............................. <1>
  [ 14] pusharglistnoret 2 ...................... <me.big, 1>
  [ 16] objcall 494 ............................. me.big.setEnergy(1)
  [ 19] getparam 0 .............................. <me>
  [ 21] getchainedprop 51 ....................... <me.big>
  [ 23] pushsymb 493 ............................ <#beBuilt>
  [ 26] pusharglist 2 ........................... <me.big, #beBuilt>
  [ 28] objcall 20 .............................. <me.big.getNoOfFramesInStrip(#beBuilt)>
  [ 30] setlocal 0 .............................. lengthOfBuildAnim = me.big.getNoOfFramesInStrip(#beBuilt)
  [ 32] pushint8 1 .............................. <1>
  [ 34] pushzero ................................ <0>
  [ 35] getlocal 0 .............................. <lengthOfBuildAnim>
  [ 37] pusharglist 2 ........................... <[0, lengthOfBuildAnim]>
  [ 39] pushlist ................................ <[0, lengthOfBuildAnim]>
  [ 40] pusharglist 2 ........................... <1, [0, lengthOfBuildAnim]>
  [ 42] extcall 495 ............................. <varPercent(1, [0, lengthOfBuildAnim])>
  [ 45] setprop 489 ............................. pPercentToAddPerFrame = varPercent(1, [0, lengthOfBuildAnim])
  [ 48] ret
end

on startBuilding me
  [  0] getprop 490 ............................. <pPreBuilt>
  [  3] jmpifz [ 16] ............................ if pPreBuilt then / else
  [  6] getparam 0 .............................. <me>
  [  8] pusharglistnoret 1 ...................... <me>
  [ 10] objcall 482 ............................. me.buildingFinished()
  [ 13] jmp [ 28]
  [ 16] getparam 0 .............................. <me>
  [ 18] getchainedprop 51 ....................... <me.big>
  [ 20] pushsymb 493 ............................ <#beBuilt>
  [ 23] pusharglistnoret 2 ...................... <me.big, #beBuilt>
