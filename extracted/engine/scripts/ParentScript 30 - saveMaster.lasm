property pSaveVersion
global g, gGameSaveFile

on new me
  [  0] getparam 0 .............................. <me>
  [  2] pusharglistnoret 1 ...................... <me>
  [  4] extcall 3 ............................... return me
  [  6] ret
end

on init me
  [  0] pushint8 12 ............................. <12>
  [  2] setprop 1343 ............................ pSaveVersion = 12
  [  5] ret
end

on finish me
  [  0] ret
end

on isLoadAvailable me
  [  0] pushzero ................................ <0>
  [  1] setlocal 0 .............................. available = 0
  [  3] gettoplevelprop 2127 .................... <_player>
  [  6] getglobal 1345 .......................... <gGameSaveFile>
  [  9] pusharglist 2 ........................... <_player, gGameSaveFile>
