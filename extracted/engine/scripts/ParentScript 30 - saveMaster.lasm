  [108] pusharglistnoret 1 ...................... <g.characterEnergyRollOverMaster>
  [110] objcall 835 ............................. g.characterEnergyRollOverMaster.restoreFromSave()
  [113] ret
end

on isMenuItemShadowed me, theComm
  [  0] getparam 1 .............................. <theComm>
  [  2] peek 0 .................................. case theComm of
  [  4] pushsymb 547 ............................ <#loadGame>
  [  7] eq
  [  8] jmpifz [ 31] ............................ (case) #loadGame:
  [ 11] getparam 0 .............................. <me>
  [ 13] pusharglist 1 ........................... <me>
  [ 15] objcall 1342 ............................ <me.isLoadAvailable()>
  [ 18] jmpifz [ 27] ............................ if me.isLoadAvailable() then / else
  [ 21] pushzero ................................ <0>
  [ 22] setlocal 0 .............................. shadowed = 0
  [ 24] jmp [ 31]
  [ 27] pushint8 1 .............................. <1>
  [ 29] setlocal 0 .............................. shadowed = 1
  [ 31] pop 1
  [ 33] getlocal 0 .............................. <shadowed>
  [ 35] pusharglistnoret 1 ...................... <shadowed>
  [ 37] extcall 3 ............................... return shadowed
  [ 39] ret
end

