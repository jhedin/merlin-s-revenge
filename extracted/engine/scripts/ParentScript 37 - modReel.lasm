  [ 15] eq
  [ 16] jmpifz [ 42] ............................ (case) #reelFinished:
  [ 19] getparam 0 .............................. <me>
  [ 21] pusharglist 1 ........................... <me>
  [ 23] objcall 499 ............................. <me.checkDead()>
  [ 26] pushzero ................................ <0>
  [ 27] eq ...................................... <me.checkDead() = 0>
  [ 28] jmpifz [ 42] ............................ if me.checkDead() = 0 then
