  [  2] pusharglist 1 ........................... <me>
  [  4] objcall 1063 ............................ <me.getVectX()>
  [  7] setlocal 0 .............................. vectX = me.getVectX()
  [  9] getlocal 0 .............................. <vectX>
  [ 11] pusharglist 1 ........................... <vectX>
