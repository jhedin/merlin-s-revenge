on updateRecoil me
  [  0] pushzero ................................ <0>
  [  1] setlocal 0 .............................. fin = 0
  [  3] getprop 1048 ............................ <pRecoilCounter>
  [  6] getobjprop 552 .......................... <pRecoilCounter.fin>
  [  9] jmpifz [ 16] ............................ if pRecoilCounter.fin then
  [ 12] pushint8 1 .............................. <1>
  [ 14] setlocal 0 .............................. fin = 1
  [ 16] getprop 1048 ............................ <pRecoilCounter>
  [ 19] pusharglistnoret 1 ...................... <pRecoilCounter>
  [ 21] extcall 553 ............................. counter(pRecoilCounter)
  [ 24] getlocal 0 .............................. <fin>
  [ 26] pusharglistnoret 1 ...................... <fin>
  [ 28] extcall 35 .............................. return fin
  [ 30] ret
end

