property pLoc, pMedikitDisplayer
global g

on new me
  [  0] getparam 0 .............................. <me>
  [  2] pusharglistnoret 1 ...................... <me>
  [  4] extcall 3 ............................... return me
  [  6] ret
end

on init me
  [  0] pushzero ................................ <0>
  [  1] pushzero ................................ <0>
  [  2] pusharglist 2 ........................... <0, 0>
  [  4] extcall 122 ............................. <point(0, 0)>
  [  6] setprop 1135 ............................ pLoc = point(0, 0)
  [  9] pushsymb 103 ............................ <#none>
  [ 11] setprop 1136 ............................ pMedikitDisplayer = #none
  [ 14] ret
end

on finish me
  [  0] getprop 1136 ............................ <pMedikitDisplayer>
  [  3] pusharglist 1 ........................... <pMedikitDisplayer>
  [  5] extcall 350 ............................. <ilk(pMedikitDisplayer)>
  [  8] pushsymb 388 ............................ <#void>
  [ 11] nteq .................................... <ilk(pMedikitDisplayer) <> #void>
  [ 12] getprop 1136 ............................ <pMedikitDisplayer>
  [ 15] pushsymb 103 ............................ <#none>
  [ 17] nteq .................................... <pMedikitDisplayer <> #none>
  [ 18] and ..................................... <(ilk(pMedikitDisplayer) <> #void) and (pMedikitDisplayer <> #none)>
  [ 19] jmpifz [ 34] ............................ if (ilk(pMedikitDisplayer) <> #void) and (pMedikitDisplayer <> #none) then
  [ 22] getprop 1136 ............................ <pMedikitDisplayer>
  [ 25] pusharglistnoret 1 ...................... <pMedikitDisplayer>
  [ 27] objcall 239 ............................. pMedikitDisplayer.finish()
  [ 29] pushsymb 103 ............................ <#none>
  [ 31] setprop 1136 ............................ pMedikitDisplayer = #none
