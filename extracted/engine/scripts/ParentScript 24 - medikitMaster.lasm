  [ 61] extcall 193 ............................. <member("medikit_on", "gfx")>
  [ 63] setobjprop 1140 ......................... params.onMember = member("medikit_on", "gfx")
  [ 66] getprop 1136 ............................ <pMedikitDisplayer>
  [ 69] getlocal 0 .............................. <params>
  [ 71] pusharglistnoret 2 ...................... <pMedikitDisplayer, params>
  [ 73] objcall 1 ............................... pMedikitDisplayer.init(params)
  [ 75] ret
end

on stop me
  [  0] getparam 0 .............................. <me>
  [  2] pusharglistnoret 1 ...................... <me>
  [  4] objcall 239 ............................. me.finish()
  [  6] ret
end

on updateDisplay me, theObj
  [  0] getprop 1136 ............................ <pMedikitDisplayer>
  [  3] getparam 1 .............................. <theObj>
  [  5] pusharglistnoret 2 ...................... <pMedikitDisplayer, theObj>
  [  7] objcall 1141 ............................ pMedikitDisplayer.updateDisplayFromObj(theObj)
