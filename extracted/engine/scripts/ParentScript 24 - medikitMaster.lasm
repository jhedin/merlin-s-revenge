end

on start me, theloc
  [  0] getparam 1 .............................. <theloc>
  [  2] setprop 1135 ............................ pLoc = theloc
  [  5] getglobal 191 ........................... <g>
  [  7] getchainedprop 336 ...................... <g.objectMaster>
  [ 10] pushsymb 1137 ........................... <#objMedikitDisplayer>
  [ 13] pusharglist 2 ........................... <g.objectMaster, #objMedikitDisplayer>
  [ 15] objcall 338 ............................. <g.objectMaster.requestObject(#objMedikitDisplayer)>
  [ 18] setprop 1136 ............................ pMedikitDisplayer = g.objectMaster.requestObject(#objMedikitDisplayer)
  [ 21] getprop 1136 ............................ <pMedikitDisplayer>
  [ 24] pushsymb 1 .............................. <#init>
  [ 26] pusharglist 2 ........................... <pMedikitDisplayer, #init>
  [ 28] objcall 339 ............................. <pMedikitDisplayer.getParams(#init)>
  [ 31] setlocal 0 .............................. params = pMedikitDisplayer.getParams(#init)
  [ 33] getlocal 0 .............................. <params>
  [ 35] getparam 1 .............................. <theloc>
  [ 37] setobjprop 1138 ......................... params.displayLoc = theloc
  [ 40] getlocal 0 .............................. <params>
  [ 42] pushcons 0 .............................. <"medikit_off">
  [ 44] pushcons 1 .............................. <"gfx">
  [ 46] pusharglist 2 ........................... <"medikit_off", "gfx">
  [ 48] extcall 193 ............................. <member("medikit_off", "gfx")>
  [ 50] setobjprop 1139 ......................... params.offMember = member("medikit_off", "gfx")
  [ 53] getlocal 0 .............................. <params>
