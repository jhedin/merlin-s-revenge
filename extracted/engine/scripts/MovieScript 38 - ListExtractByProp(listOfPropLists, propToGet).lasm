on ListExtractByProp listOfPropLists, propToGet
  [  0] pusharglist 0 ........................... <[]>
  [  2] pushlist ................................ <[]>
  [  3] setlocal 0 .............................. thelist = []
  [  5] getparam 0 .............................. <listOfPropLists>
  [  7] peek 0
  [  9] pusharglist 1
  [ 11] extcall 17
  [ 13] pushint8 1
  [ 15] peek 0
  [ 17] peek 2
  [ 19] lteq
  [ 20] jmpifz [ 52] ............................ repeat with prList in listOfPropLists
  [ 23] peek 2
  [ 25] peek 1
  [ 27] pusharglist 2
  [ 29] extcall 18
  [ 31] setlocal 1
  [ 33] getlocal 0 .............................. <thelist>
  [ 35] getlocal 1 .............................. <prList>
  [ 37] getparam 1 .............................. <propToGet>
  [ 39] pusharglist 2 ........................... <prList, propToGet>
  [ 41] objcall 18 .............................. <prList[propToGet]>
  [ 43] pusharglistnoret 2 ...................... <thelist, prList[propToGet]>
  [ 45] objcall 83 .............................. thelist.append(prList[propToGet])
  [ 47] pushint8 1
  [ 49] add
  [ 50] endrepeat [ 15]
  [ 52] pop 3
  [ 54] getlocal 0 .............................. <thelist>
  [ 56] pusharglistnoret 1 ...................... <thelist>
  [ 58] extcall 3 ............................... return thelist
  [ 60] ret
end
