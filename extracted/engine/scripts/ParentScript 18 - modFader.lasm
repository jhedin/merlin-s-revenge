  [ 12] pushsymb 49 ............................. <#none>
  [ 14] nteq .................................... <sd.pTransBlend <> #none>
  [ 15] jmpifz [ 72] ............................ if sd.pTransBlend <> #none then
  [ 18] getglobal 40 ............................ <g>
  [ 20] getchainedprop 41 ....................... <g.objectMaster>
  [ 22] pushsymb 684 ............................ <#objTransBlend>
  [ 25] pusharglist 2 ........................... <g.objectMaster, #objTransBlend>
