  [  0] getprop 683 ............................. <pTransBlend>
  [  3] pushsymb 49 ............................. <#none>
  [  5] nteq .................................... <pTransBlend <> #none>
  [  6] jmpifz [ 21] ............................ if pTransBlend <> #none then
