  [  3] pushsymb 49 ............................. <#none>
  [  5] nteq .................................... <pTransBlend <> #none>
  [  6] jmpifz [ 37] ............................ if pTransBlend <> #none then / else
  [  9] pusharglist 0 ........................... <[:]>
  [ 11] pushproplist ............................ <[:]>
  [ 12] setlocal 0 .............................. saveData = [:]
  [ 14] getprop 683 ............................. <pTransBlend>
  [ 17] getlocal 0 .............................. <saveData>
