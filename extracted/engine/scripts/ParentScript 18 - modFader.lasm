  [ 11] pushsymb 690 ............................ <#in>
  [ 14] eq
  [ 15] jmpifz [ 25] ............................ (case) #in:
  [ 18] pushint8 100 ............................ <100>
  [ 20] setlocal 0 .............................. targetValue = 100
  [ 22] jmp [ 37]
  [ 25] peek 0
  [ 27] pushsymb 689 ............................ <#out>
  [ 30] eq
  [ 31] jmpifz [ 37] ............................ (case) #out:
