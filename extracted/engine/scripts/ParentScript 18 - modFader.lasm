  [ 51] pusharglist 1 ........................... <me.big>
  [ 53] objcall 97 .............................. <me.big.getSprite()>
  [ 55] pusharglistnoret 2 ...................... <pTransBlend, me.big.getSprite()>
  [ 57] objcall 686 ............................. pTransBlend.setSprite(me.big.getSprite())
  [ 60] getprop 683 ............................. <pTransBlend>
  [ 63] getparam 1 .............................. <sd>
  [ 65] getobjprop 683 .......................... <sd.pTransBlend>
  [ 68] pusharglistnoret 2 ...................... <pTransBlend, sd.pTransBlend>
  [ 70] objcall 26 .............................. pTransBlend.restoreFromSave(sd.pTransBlend)
  [ 72] getprop 33 .............................. <ancestor>
  [ 74] getparam 1 .............................. <sd>
  [ 76] pusharglistnoret 2 ...................... <ancestor, sd>
  [ 78] objcall 26 .............................. ancestor.restoreFromSave(sd)
  [ 80] ret
end

on setBlend me, val
