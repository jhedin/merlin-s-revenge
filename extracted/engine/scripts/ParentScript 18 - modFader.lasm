  [ 21] objcall 4 ............................... pTransBlend.addSaveData(saveData)
  [ 23] getparam 1 .............................. <sd>
  [ 25] pushsymb 683 ............................ <#pTransBlend>
  [ 28] getlocal 0 .............................. <saveData>
  [ 30] pusharglistnoret 3 ...................... <sd, #pTransBlend, saveData>
  [ 32] objcall 48 .............................. sd[#pTransBlend] = saveData
  [ 34] jmp [ 48]
  [ 37] getparam 1 .............................. <sd>
  [ 39] pushsymb 683 ............................ <#pTransBlend>
  [ 42] pushsymb 49 ............................. <#none>
  [ 44] pusharglistnoret 3 ...................... <sd, #pTransBlend, #none>
  [ 46] objcall 48 .............................. sd[#pTransBlend] = #none
  [ 48] getprop 33 .............................. <ancestor>
  [ 50] getparam 1 .............................. <sd>
  [ 52] pusharglistnoret 2 ...................... <ancestor, sd>
  [ 54] objcall 4 ............................... ancestor.addSaveData(sd)
  [ 56] ret
end

