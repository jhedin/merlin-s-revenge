  [ 49] pushint8 1 .............................. <1>
  [ 51] setprop 781 ............................. pMedikitActive = 1
  [ 54] getparam 0 .............................. <me>
  [ 56] pusharglistnoret 1 ...................... <me>
  [ 58] objcall 775 ............................. me.updateMedikitDisplay()
  [ 61] jmp [ 82]
  [ 64] pushzero ................................ <0>
  [ 65] setprop 781 ............................. pMedikitActive = 0
  [ 68] getparam 0 .............................. <me>
  [ 70] pusharglistnoret 1 ...................... <me>
  [ 72] objcall 773 ............................. me.nextMedikit()
  [ 75] getparam 0 .............................. <me>
  [ 77] pusharglistnoret 1 ...................... <me>
  [ 79] objcall 775 ............................. me.updateMedikitDisplay()
  [ 82] ret
end

