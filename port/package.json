{
  "name": "merlins-revenge",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "TypeScript/HTML5 port of the Director/Lingo game Merlin's Revenge",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "parse-data": "tsx tools/parse_data.ts",
    "build-assets": "tsx tools/build_assets.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
